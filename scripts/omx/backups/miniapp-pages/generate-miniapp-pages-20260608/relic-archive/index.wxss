.mvp-page {
  padding-top: 48rpx;
}

.page-title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
}

.page-desc,
.detail-copy,
.card-meta {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.page-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.boundary-panel {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #263a34;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.5;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 30rpx;
}

.relic-card {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.card-status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #e8d8b4;
  color: #263a34;
  font-size: 22rpx;
  font-weight: 800;
}

.detail-row {
  display: grid;
  grid-template-columns: 88rpx 1fr;
  gap: 16rpx;
  margin-top: 18rpx;
}

.detail-label {
  color: #7f4f24;
  font-size: 24rpx;
  font-weight: 800;
}
