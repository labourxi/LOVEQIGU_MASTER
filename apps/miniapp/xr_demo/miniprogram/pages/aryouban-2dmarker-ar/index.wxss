.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f4f1eb;
}

.card {
  background: #fffdf9;
  border: 1rpx solid rgba(47, 42, 38, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2a26;
}

.copy {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5b534c;
  line-height: 1.5;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2a26;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0;
  font-size: 24rpx;
  color: #2f2a26;
  border-top: 1rpx solid rgba(47, 42, 38, 0.06);
}

.row:first-of-type {
  border-top: none;
}

.row text:first-child {
  color: #6a6058;
}

.row text:last-child {
  text-align: right;
  word-break: break-all;
}

.action-btn {
  margin-top: 20rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background: #2f2a26;
  color: #fff;
}
