<view class="page">
  <view class="hero">
    <view class="title">微信 XR Renderer Spike</view>
    <view class="subtitle">{{runtimeMessage}}</view>
    <view class="hint">{{renderHint}}</view>
  </view>

  <view class="card">
    <view class="card-title">Capability Probe</view>
    <view class="row"><text>XR_FRAME_EXISTS</text><text>{{xrFrameExists ? 'YES' : 'NO'}}</text></view>
    <view class="row"><text>CAMERA_READY</text><text>{{cameraReady ? 'YES' : 'NO'}}</text></view>
    <view class="row"><text>XR_SCENE_READY</text><text>{{xrSceneReady ? 'YES' : 'NO'}}</text></view>
    <view class="row"><text>XR_OBJECT_RENDER_READY</text><text>{{xrObjectRenderReady ? 'YES' : 'NO'}}</text></view>
  </view>

  <view class="card">
    <view class="card-title">Runtime Preview</view>
    <view class="preview">
      <camera wx:if="{{cameraReady}}" class="camera" device-position="back"></camera>
      <view wx:else class="placeholder">
        <view class="placeholder-title">Camera / XR unavailable</view>
        <view class="placeholder-copy">This spike only confirms runtime support. No XR renderer is bound yet.</view>
      </view>
    </view>
  </view>
</view>
