.page {
  min-height: 100vh;
  background: #f4f1eb;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero, .card {
  background: #fffdf9;
  border: 1rpx solid rgba(47, 42, 38, 0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2f2a26;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #5b534c;
}

.hint {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9a7b2f;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2a26;
  margin-bottom: 16rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  font-size: 24rpx;
  color: #2f2a26;
  border-top: 1rpx solid rgba(47, 42, 38, 0.06);
}

.row:first-of-type {
  border-top: none;
}

.preview {
  min-height: 440rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #1f1b18;
}

.camera {
  width: 100%;
  height: 440rpx;
}

.placeholder {
  min-height: 440rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  color: #f8f6f2;
  padding: 24rpx;
  text-align: center;
}

.placeholder-title {
  font-size: 30rpx;
  font-weight: 600;
}

.placeholder-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  opacity: 0.8;
}
