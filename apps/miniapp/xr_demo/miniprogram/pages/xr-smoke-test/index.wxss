.page {
  min-height: 100vh;
}

.primitive-entry-panel {
  margin: 16px;
  padding: 16px;
  border-radius: 12px;
  background: #fff6d8;
  border: 1px solid #e0b85a;
}

.primitive-entry-button {
  width: 100%;
  min-height: 48px;
  line-height: 48px;
  font-size: 16px;
  font-weight: 600;
  background: #1f3f35;
  color: #ffffff;
  border-radius: 24px;
}

.primitive-entry-hint {
  display: block;
  margin-top: 8px;
  font-size: 12px;
  color: #6f6040;
}

.simple3d-diagnostics-panel {
  margin: 16px 0;
  padding: 14px;
  border-radius: 12px;
  background: #fff6d8;
  border: 1px solid #e0b85a;
}

.simple3d-diagnostics-button {
  width: 100%;
  min-height: 46px;
  line-height: 46px;
  font-size: 16px;
  font-weight: 600;
  background: #1f3f35;
  color: #ffffff;
  border-radius: 24px;
}

.simple3d-diagnostics-hint {
  margin-top: 8px;
  font-size: 12px;
  color: #6f6040;
}

.scenic-point-entry-panel {
  margin: 16rpx 0 0;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f6f7fb;
  border: 1px solid #d7dbe8;
}

.scenic-point-entry-button {
  width: 100%;
  min-height: 46rpx;
  line-height: 46rpx;
  font-size: 16rpx;
  font-weight: 600;
  background: #2e3d66;
  color: #ffffff;
  border-radius: 24rpx;
}

.scenic-point-entry-hint {
  margin-top: 8rpx;
  font-size: 12rpx;
  color: #66708a;
}

.scenic-point-result-message {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  background: #fff7e6;
  color: #8a5b00;
  font-size: 12rpx;
  line-height: 1.6;
}

.xr-simple-3d-inline-surface-box {
  margin: 16px 0;
  width: 100%;
  height: 260px;
  min-height: 260px;
  border-radius: 12px;
  overflow: hidden;
  background: #111;
  border: 1px solid #d8ccb8;
}

.xr-simple-3d-inline-surface-box xr-scene {
  width: 100%;
  height: 260px;
  display: block;
}

.xr-simple-3d-inline-surface-box xr-frame {
  width: 100%;
  height: 260px;
  display: block;
}

.xr-simple-3d-inline-surface-box.is-idle {
  opacity: 0.35;
}

.xr-simple-3d-inline-surface-box.is-active {
  opacity: 1;
}
