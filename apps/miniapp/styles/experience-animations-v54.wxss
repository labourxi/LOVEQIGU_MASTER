
/* ═══════════════════════════════════════════════
   V5.4 EXPERIENCE SYSTEM — 仪式化体验动画层
   ═══════════════════════════════════════════════ */

/* ─── UI 情感层级（Emotion Layer Chassis） ─── */
.ui-background-layer {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.ui-ambient-layer {
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  overflow: hidden;
}

.ui-interaction-layer {
  position: relative;
  z-index: 2;
}

/* ─── 氛围呼吸光 ─── */
@keyframes ambient-breath-glow {
  0%, 100% { opacity: 0.15; transform: scale(1); }
  50% { opacity: 0.30; transform: scale(1.05); }
}

.ambient-glow {
  position: absolute;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(244, 215, 166, 0.08) 0%, transparent 70%);
  animation: ambient-breath-glow 6s ease-in-out infinite;
}

.ambient-glow--top {
  top: -80rpx;
  right: -60rpx;
  width: 500rpx;
  height: 500rpx;
}

.ambient-glow--bottom {
  bottom: -100rpx;
  left: -80rpx;
  width: 450rpx;
  height: 450rpx;
  animation-delay: -3s;
}

/* ─── 粒子光点（静态装饰） ─── */
@keyframes particle-float {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.3; }
  50% { transform: translateY(-20rpx) scale(1.1); opacity: 0.6; }
}

.ambient-particle {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: rgba(244, 215, 166, 0.3);
  animation: particle-float 4s ease-in-out infinite;
}

/* ─── 探索节点 Glow 反馈 ─── */
@keyframes node-glow-flash {
  0% { box-shadow: 0 0 0 0 rgba(244, 215, 166, 0); }
  30% { box-shadow: 0 0 20rpx 10rpx rgba(244, 215, 166, 0.4); }
  100% { box-shadow: 0 0 0 0 rgba(244, 215, 166, 0); }
}

.atlas-node--next:active,
.atlas-timeline__item--next:active {
  animation: node-glow-flash 0.6s ease-out;
}

/* ─── 信物显现动画（Relic Reveal） ─── */
@keyframes relic-reveal-delay {
  0% { opacity: 0; }
  100% { opacity: 0; }
}

@keyframes relic-reveal-particle {
  0% { transform: scale(0.2); opacity: 0; filter: blur(10rpx); }
  50% { transform: scale(0.8); opacity: 0.6; filter: blur(4rpx); }
  100% { transform: scale(1); opacity: 1; filter: blur(0); }
}

@keyframes relic-reveal-glow {
  0% { box-shadow: 0 0 0 0 rgba(244, 215, 166, 0); }
  50% { box-shadow: 0 0 40rpx 20rpx rgba(244, 215, 166, 0.3); }
  100% { box-shadow: 0 0 0 0 rgba(244, 215, 166, 0); }
}

.relic-reveal-stage--delay {
  animation: relic-reveal-delay var(--relic-delay, 0.5s) ease-out forwards;
}

.relic-reveal-stage--particle {
  animation: relic-reveal-particle 0.6s ease-out both;
}

.relic-reveal-stage--glow {
  animation: relic-reveal-glow 0.8s ease-out both;
}

.relic-reveal-stage--reveal {
  opacity: 1;
  transition: opacity 0.5s ease-out;
}

/* ─── XR 节奏黑场过渡 ─── */
@keyframes xr-blackout-fadein {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

@keyframes xr-blackout-fadeout {
  0% { opacity: 1; }
  100% { opacity: 0; }
}

.xr-blackout-overlay {
  position: fixed;
  inset: 0;
  z-index: 2000;
  background: #000;
  animation: xr-blackout-fadein 0.4s ease-out forwards;
}

.xr-blackout-overlay--out {
  animation: xr-blackout-fadeout 0.4s ease-in forwards;
}

/* ─── XR 环境生成过渡 ─── */
@keyframes xr-environment-enter {
  0% { filter: brightness(0) saturate(0); }
  100% { filter: brightness(1) saturate(1); }
}

.xr-environment-stage {
  animation: xr-environment-enter 1.2s ease-out forwards;
}

/* ─── 信物显现完成态 ─── */
@keyframes relic-stable-glow {
  0%, 100% { box-shadow: 0 0 8rpx 2rpx rgba(244, 215, 166, 0.15); }
  50% { box-shadow: 0 0 16rpx 6rpx rgba(244, 215, 166, 0.25); }
}

.relic-stable {
  animation: relic-stable-glow 4s ease-in-out infinite;
}
