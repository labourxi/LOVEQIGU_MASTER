/** Shared Eastern-aesthetic prototype styles — import in page wxss via @import */

.proto-page {
  min-height: 100vh;
  padding: 0 28rpx 48rpx;
  background: #f4f1eb;
  color: #111827;
}

.proto-hero {
  margin: 0 -28rpx 32rpx;
  padding: 48rpx 40rpx 40rpx;
  background: linear-gradient(145deg, #263a34 0%, #1f302b 100%);
  color: #fff;
  border-radius: 0 0 32rpx 32rpx;
}

.proto-kicker {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  margin-bottom: 12rpx;
}

.proto-title {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.proto-subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.proto-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.proto-stat {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.proto-stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #f4d7a6;
}

.proto-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

.proto-section {
  margin-bottom: 32rpx;
}

.proto-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.proto-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #263a34;
}

.proto-section-more {
  font-size: 24rpx;
  color: #4b635c;
}

.proto-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.proto-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.proto-card-meta {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.proto-card-copy {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-top: 12rpx;
}

.proto-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  background: #e8efe9;
  color: #4b635c;
}

.proto-badge--gold {
  background: #f4d7a6;
  color: #6b4220;
}

.proto-badge--warm {
  background: #fff7ed;
  color: #7f4f24;
}

.proto-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.proto-btn {
  margin: 0;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #f4d7a6;
  color: #263a34;
}

.proto-btn::after {
  border: 0;
}

.proto-btn--ghost {
  background: transparent;
  color: #4b635c;
  border: 1rpx solid #d1d5db;
}

.proto-btn--primary {
  background: #263a34;
  color: #f4d7a6;
}

.proto-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.proto-link-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.proto-link-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #263a34;
}

.proto-link-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.proto-progress-bar {
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.proto-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4b635c, #263a34);
  border-radius: 999rpx;
}

.proto-note {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
  margin-top: 16rpx;
}

.proto-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.proto-chip {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #faf8f4;
  color: #4b635c;
  border: 1rpx solid #e5e7eb;
}

.proto-chip--lit {
  background: #263a34;
  color: #f4d7a6;
  border-color: #263a34;
}

.proto-chip--dim {
  opacity: 0.45;
}
