/** Shared Eastern-aesthetic prototype styles — DESIGN FREEZE V3
 *
 * LOCKED Colors:
 *   primary: #0F2A22     background: #F3F0E8
 *   accent:  #C8A24A     shadow:    rgba(0,0,0,0.15)
 */

.proto-page {
  min-height: 100vh;
  padding: 0 28rpx 48rpx;
  background: #F3F0E8;
  color: #111827;
}

.proto-hero {
  margin: 0 -28rpx 32rpx;
  padding: 48rpx 40rpx 40rpx;
  background: linear-gradient(145deg, #0F2A22 0%, #0F2A22 100%);
  color: #fff;
  border-radius: 0 0 32rpx 32rpx;
}

.proto-kicker {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  margin-bottom: 12rpx;
}

.proto-title {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.3;
  margin-bottom: 12rpx;
}

.proto-subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
}

.proto-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.proto-stat {
  flex: 1;
  min-width: 180rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.proto-stat-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #C8A24A;
}

.proto-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

/* ─── Section — 留白增强 30% ─── */
.proto-section {
  margin-bottom: 42rpx;
}

.proto-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.proto-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0F2A22;
}

.proto-section-more {
  font-size: 24rpx;
  color: #4b635c;
}

/* ─── 卡片叠层系统 ─── */
.proto-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow:
    0 8rpx 24rpx rgba(0, 0, 0, 0.15),
    0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.proto-card + .proto-card {
  margin-top: -8rpx;
}

.proto-card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.proto-card-meta {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.proto-card-copy {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-top: 12rpx;
}

.proto-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  background: #e8efe9;
  color: #4b635c;
}

.proto-badge--gold {
  background: #C8A24A;
  color: #6b4220;
}

.proto-badge--warm {
  background: #fff7ed;
  color: #7f4f24;
}

.proto-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* ─── 按钮系统 — 浮层阴影 + 呼吸感 ─── */
.proto-btn {
  margin: 0;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #C8A24A;
  color: #0F2A22;
  box-shadow:
    0 4rpx 12rpx rgba(200, 162, 74, 0.35),
    0 2rpx 4rpx rgba(200, 162, 74, 0.2);
  transition: all 0.3s ease;
}

/* 呼吸感动画 — 阴影脉动 */
@keyframes proto-btn-breathe {
  0%, 100% { box-shadow: 0 4rpx 12rpx rgba(200, 162, 74, 0.35), 0 2rpx 4rpx rgba(200, 162, 74, 0.2); }
  50% { box-shadow: 0 6rpx 20rpx rgba(200, 162, 74, 0.55), 0 3rpx 8rpx rgba(200, 162, 74, 0.3); }
}

.proto-btn:not([disabled]) {
  animation: proto-btn-breathe 3s ease-in-out infinite;
}

.proto-btn[disabled] {
  opacity: 0.5;
  animation: none;
}

.proto-btn::after {
  border: 0;
}

/* ─── 主要按钮 — 深色呼吸 ─── */
.proto-btn--primary {
  background: #0F2A22;
  color: #C8A24A;
  box-shadow:
    0 4rpx 12rpx rgba(15, 42, 34, 0.30),
    0 2rpx 4rpx rgba(15, 42, 34, 0.15);
}

@keyframes proto-btn-primary-breathe {
  0%, 100% { box-shadow: 0 4rpx 12rpx rgba(15, 42, 34, 0.30), 0 2rpx 4rpx rgba(15, 42, 34, 0.15); }
  50% { box-shadow: 0 6rpx 24rpx rgba(15, 42, 34, 0.50), 0 4rpx 10rpx rgba(15, 42, 34, 0.25); }
}

.proto-btn--primary:not([disabled]) {
  animation: proto-btn-primary-breathe 3.5s ease-in-out infinite;
}

/* ─── 幽灵按钮 ─── */
.proto-btn--ghost {
  background: transparent;
  color: #4b635c;
  border: 1rpx solid #d1d5db;
  box-shadow: none;
  animation: none;
}

/* ─── 浮动按钮（层级最高） ─── */
.proto-btn--float {
  background: #C8A24A;
  color: #0F2A22;
  box-shadow:
    0 8rpx 28rpx rgba(200, 162, 74, 0.40),
    0 4rpx 12rpx rgba(200, 162, 74, 0.25);
}

@keyframes proto-btn-float-breathe {
  0%, 100% { box-shadow: 0 8rpx 28rpx rgba(200, 162, 74, 0.40), 0 4rpx 12rpx rgba(200, 162, 74, 0.25); transform: translateY(0); }
  50% { box-shadow: 0 12rpx 36rpx rgba(200, 162, 74, 0.60), 0 6rpx 20rpx rgba(200, 162, 74, 0.35); transform: translateY(-4rpx); }
}

.proto-btn--float:not([disabled]) {
  animation: proto-btn-float-breathe 4s ease-in-out infinite;
}

.proto-grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.proto-link-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.proto-link-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F2A22;
}

.proto-link-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

.proto-progress-bar {
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.proto-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4b635c, #0F2A22);
  border-radius: 999rpx;
}

.proto-note {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.5;
  margin-top: 16rpx;
}

.proto-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.proto-chip {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #faf8f4;
  color: #4b635c;
  border: 1rpx solid #e5e7eb;
}

.proto-chip--lit {
  background: #0F2A22;
  color: #C8A24A;
  border-color: #0F2A22;
}

.proto-chip--dim {
  opacity: 0.45;
}
