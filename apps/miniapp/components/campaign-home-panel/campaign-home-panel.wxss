.campaign-panel {
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  background: #fff7ed;
  border: 1rpx dashed rgba(154, 52, 18, 0.28);
}

.campaign-panel-badge {
  color: #9a3412;
  font-size: 22rpx;
  font-weight: 700;
}

.campaign-panel-title {
  margin-top: 12rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
}

.campaign-panel-copy {
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.campaign-panel-note {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(17, 24, 39, 0.08);
  color: #9a3412;
  font-size: 22rpx;
  line-height: 1.45;
}
