.user-bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  width: 100%;
  box-sizing: border-box;
  padding: 8rpx 0 calc(8rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(38, 58, 52, 0.12);
  background: #faf8f4;
  box-shadow: 0 -6rpx 20rpx rgba(38, 58, 52, 0.08);
}

.user-bottom-nav__item {
  flex: 1 1 0;
  min-width: 0;
  max-width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 4rpx;
  color: #6b7280;
  box-sizing: border-box;
}

.user-bottom-nav__item.is-active {
  color: #263a34;
}

.user-bottom-nav__item.is-active .user-bottom-nav__label {
  color: #263a34;
  font-weight: 700;
}

.user-bottom-nav__glyph {
  display: none;
}

.user-bottom-nav__label {
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.2;
  white-space: nowrap;
  text-align: center;
  letter-spacing: 0;
}

.user-bottom-nav__item.is-active::before {
  content: '';
  display: block;
  width: 28rpx;
  height: 4rpx;
  margin-bottom: 6rpx;
  border-radius: 2rpx;
  background: #b68a3d;
}
