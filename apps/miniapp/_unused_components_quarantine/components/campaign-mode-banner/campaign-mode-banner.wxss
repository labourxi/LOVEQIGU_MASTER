.campaign-banner {
  padding: 22rpx 24rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #fff1e6, #fde4cc);
  border: 1rpx solid rgba(154, 52, 18, 0.12);
}

.campaign-badge {
  color: #9a3412;
  font-size: 22rpx;
  font-weight: 700;
}

.campaign-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.campaign-copy {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}
