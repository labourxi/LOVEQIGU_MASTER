.explore-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.home-entry-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.home-entry-card {
  padding: 22rpx 24rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.home-entry-card--star {
  background: linear-gradient(145deg, #263a34, #1f302b);
}

.home-entry-card--star .home-entry-label,
.home-entry-card--star .home-entry-value,
.home-entry-card--star .home-entry-link {
  color: #f4f1eb;
}

.home-entry-card--star .home-entry-value {
  color: #f4d7a6;
}

.home-entry-card--meridian {
  background: linear-gradient(145deg, #4b635c, #3a4f49);
}

.home-entry-card--meridian .home-entry-label,
.home-entry-card--meridian .home-entry-value,
.home-entry-card--meridian .home-entry-link {
  color: #f4f1eb;
}

.home-entry-card--meridian .home-entry-value {
  color: #e8d8b4;
}

.home-entry-banner {
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #1f302b 0%, #263a34 55%, #4b635c 100%);
  box-shadow: 0 10rpx 28rpx rgba(38, 58, 52, 0.18);
}

.home-entry-banner--active {
  opacity: 0.92;
}

.home-entry-banner-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.home-entry-banner .home-entry-label {
  color: rgba(244, 241, 235, 0.86);
}

.home-entry-banner-status {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #f4d7a6;
  font-size: 22rpx;
  font-weight: 700;
}

.home-entry-banner-value {
  margin-top: 12rpx;
  color: #f4f1eb;
  font-size: 30rpx;
  font-weight: 800;
}

.home-entry-banner .home-entry-link {
  margin-top: 12rpx;
  color: #e8d8b4;
}

.home-entry-banner--synthesis {
  background: linear-gradient(145deg, #4b635c 0%, #263a34 100%);
}

.home-entry-banner--reward {
  background: linear-gradient(145deg, #7f4f24 0%, #5c3d1e 100%);
}

.home-entry-card--active {
  opacity: 0.92;
}

.home-entry-label {
  color: #4b635c;
  font-size: 22rpx;
  font-weight: 700;
}

.home-entry-value {
  margin-top: 10rpx;
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.3;
}

.home-entry-link {
  margin-top: 10rpx;
  color: #4b635c;
  font-size: 22rpx;
  font-weight: 700;
}

.relic-summary-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.relic-summary-bar--active {
  opacity: 0.92;
}

.relic-summary-label {
  color: #111827;
  font-size: 28rpx;
  font-weight: 800;
}

.relic-summary-link {
  color: #4b635c;
  font-size: 24rpx;
  font-weight: 700;
}

.explore-hero {
  padding: 32rpx 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(145deg, #263a34, #1f302b);
  color: #f4f1eb;
}

.explore-kicker {
  color: #c9d8cf;
  font-size: 22rpx;
  font-weight: 600;
}

.explore-title {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.25;
}

.explore-copy {
  margin-top: 14rpx;
  color: rgba(244, 241, 235, 0.86);
  font-size: 26rpx;
  line-height: 1.5;
}

.explore-primary,
.entry-card,
.text-link {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: normal;
  text-align: left;
}

.explore-primary::after,
.entry-card::after,
.text-link::after {
  border: 0;
}

.explore-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 72rpx;
  margin-top: 28rpx;
  border-radius: 36rpx;
  background: #d6c08d;
  color: #15171c;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.chapter-card,
.entry-card,
.relic-item {
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.chapter-card {
  padding: 24rpx;
}

.chapter-card--active {
  opacity: 0.92;
}

.card-action {
  margin-top: 16rpx;
  color: #4b635c;
  font-size: 24rpx;
  font-weight: 600;
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-label,
.section-label {
  color: #4b635c;
  font-size: 22rpx;
  font-weight: 700;
}

.card-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.card-badge {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #e8efe9;
  color: #263a34;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.card-copy {
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.section-block {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.entry-card {
  display: block;
  box-sizing: border-box;
  width: 100%;
  padding: 24rpx;
}

.entry-card--quiet {
  background: #faf8f4;
}

.entry-title {
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
}

.entry-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.relic-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.relic-item {
  padding: 20rpx 24rpx;
}

.relic-item--active {
  opacity: 0.92;
}

.relic-name {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.relic-meta {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.empty-hint {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.text-link {
  color: #263a34;
  font-size: 24rpx;
  font-weight: 700;
}

.proto-stats-inline {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.proto-stat-inline {
  flex: 1;
  min-width: 160rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.08);
}

.proto-stat-inline-value {
  font-size: 32rpx;
  font-weight: 800;
  color: #f4d7a6;
}

.proto-stat-inline-label {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: rgba(244, 241, 235, 0.75);
}

.section-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.text-link-inline {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  color: #4b635c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: normal;
}

.text-link-inline::after {
  border: 0;
}

.scenic-scroll {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
}

.scenic-chip {
  flex: 0 0 240rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.scenic-chip-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.scenic-chip-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.proto-nav-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.proto-nav-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.proto-nav-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #263a34;
}

.proto-nav-desc {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.4;
}
