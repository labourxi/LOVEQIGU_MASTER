<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 400" width="300" height="400">
  <defs>
    <linearGradient id="cornerGrad" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="rgba(200,162,74,0.3)"/>
      <stop offset="100%" stop-color="rgba(200,162,74,0)"/>
    </linearGradient>
    <filter id="glow"><feGaussianBlur stdDeviation="1"/></filter>
  </defs>
  <!-- Corner decorations -->
  <g opacity="0.5">
    <!-- Top-left corner -->
    <path d="M10 40 L10 10 L40 10" fill="none" stroke="rgba(200,162,74,0.35)" stroke-width="1.2"/>
    <path d="M10 40 L10 10 L40 10" fill="none" stroke="rgba(200,162,74,0.1)" stroke-width="2.5" filter="url(#glow)"/>
    <circle cx="10" cy="10" r="2" fill="rgba(200,162,74,0.3)"/>
    <!-- Top-right corner -->
    <path d="M290 40 L290 10 L260 10" fill="none" stroke="rgba(200,162,74,0.35)" stroke-width="1.2"/>
    <path d="M290 40 L290 10 L260 10" fill="none" stroke="rgba(200,162,74,0.1)" stroke-width="2.5" filter="url(#glow)"/>
    <circle cx="290" cy="10" r="2" fill="rgba(200,162,74,0.3)"/>
    <!-- Bottom-left corner -->
    <path d="M10 360 L10 390 L40 390" fill="none" stroke="rgba(200,162,74,0.35)" stroke-width="1.2"/>
    <path d="M10 360 L10 390 L40 390" fill="none" stroke="rgba(200,162,74,0.1)" stroke-width="2.5" filter="url(#glow)"/>
    <circle cx="10" cy="390" r="2" fill="rgba(200,162,74,0.3)"/>
    <!-- Bottom-right corner -->
    <path d="M290 360 L290 390 L260 390" fill="none" stroke="rgba(200,162,74,0.35)" stroke-width="1.2"/>
    <path d="M290 360 L290 390 L260 390" fill="none" stroke="rgba(200,162,74,0.1)" stroke-width="2.5" filter="url(#glow)"/>
    <circle cx="290" cy="390" r="2" fill="rgba(200,162,74,0.3)"/>
  </g>
  <!-- Subtle edge lines -->
  <rect x="30" y="8" width="240" height="1" fill="rgba(200,162,74,0.06)"/>
  <rect x="30" y="391" width="240" height="1" fill="rgba(200,162,74,0.06)"/>
  <rect x="8" y="30" width="1" height="340" fill="rgba(200,162,74,0.06)"/>
  <rect x="291" y="30" width="1" height="340" fill="rgba(200,162,74,0.06)"/>
</svg>
