<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <defs>
    <filter id="glow">
      <feGaussianBlur stdDeviation="1.5" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <!-- Outer ring -->
  <circle cx="100" cy="100" r="95" fill="none" stroke="rgba(200,162,74,0.08)" stroke-width="0.8"/>
  <!-- Main ring -->
  <circle cx="100" cy="100" r="85" fill="none" stroke="rgba(200,162,74,0.15)" stroke-width="1"/>
  <!-- Inner ring -->
  <circle cx="100" cy="100" r="70" fill="none" stroke="rgba(200,162,74,0.1)" stroke-width="0.8"/>
  <!-- Dashed decorative ring -->
  <circle cx="100" cy="100" r="60" fill="none" stroke="rgba(200,162,74,0.06)" stroke-width="0.5" stroke-dasharray="3,5"/>
  <circle cx="100" cy="100" r="50" fill="none" stroke="rgba(200,162,74,0.05)" stroke-width="0.5" stroke-dasharray="2,4"/>
  <!-- Innermost ring -->
  <circle cx="100" cy="100" r="35" fill="none" stroke="rgba(200,162,74,0.12)" stroke-width="0.8"/>
  <!-- Center dot -->
  <circle cx="100" cy="100" r="3" fill="rgba(200,162,74,0.2)" filter="url(#glow)"/>
  <!-- Cardinal dots -->
  <circle cx="100" cy="17" r="1.5" fill="rgba(200,162,74,0.15)"/>
  <circle cx="100" cy="183" r="1.5" fill="rgba(200,162,74,0.15)"/>
  <circle cx="17" cy="100" r="1.5" fill="rgba(200,162,74,0.15)"/>
  <circle cx="183" cy="100" r="1.5" fill="rgba(200,162,74,0.15)"/>
</svg>
