<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 200" width="180" height="200">
  <defs>
    <linearGradient id="glassTop" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="rgba(200,162,74,0.04)"/>
      <stop offset="15%" stop-color="rgba(200,162,74,0.02)"/>
      <stop offset="100%" stop-color="rgba(200,162,74,0)"/>
    </linearGradient>
    <linearGradient id="shine" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="rgba(232,224,208,0.03)"/>
      <stop offset="40%" stop-color="rgba(232,224,208,0)"/>
      <stop offset="60%" stop-color="rgba(232,224,208,0)"/>
      <stop offset="100%" stop-color="rgba(232,224,208,0.015)"/>
    </linearGradient>
    <filter id="blur"><feGaussianBlur stdDeviation="1"/></filter>
  </defs>
  <!-- Card base shape -->
  <rect x="1" y="1" width="178" height="198" rx="20" fill="rgba(200,162,74,0.015)"/>
  <!-- Glass top reflection -->
  <rect x="1" y="1" width="178" height="60" rx="20" fill="url(#glassTop)" filter="url(#blur)"/>
  <!-- Edge border -->
  <rect x="1" y="1" width="178" height="198" rx="20" fill="none" stroke="rgba(200,162,74,0.04)" stroke-width="0.5"/>
  <!-- Diagonal shine -->
  <path d="M0 0 L180 0 L180 40 L0 70Z" fill="url(#shine)" opacity="0.5"/>
  <!-- Bottom edge gold hint -->
  <path d="M20 195 Q90 190 160 195" fill="none" stroke="rgba(200,162,74,0.025)" stroke-width="0.5"/>
</svg>
