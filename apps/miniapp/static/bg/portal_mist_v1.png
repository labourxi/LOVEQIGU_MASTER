<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 750 300" width="750" height="300">
  <defs>
    <radialGradient id="mist1" cx="30%" cy="50%" r="50%">
      <stop offset="0%" stop-color="rgba(232,224,208,0.06)"/>
      <stop offset="60%" stop-color="rgba(232,224,208,0.015)"/>
      <stop offset="100%" stop-color="rgba(232,224,208,0)"/>
    </radialGradient>
    <radialGradient id="mist2" cx="70%" cy="40%" r="45%">
      <stop offset="0%" stop-color="rgba(200,162,74,0.04)"/>
      <stop offset="50%" stop-color="rgba(200,162,74,0.01)"/>
      <stop offset="100%" stop-color="rgba(200,162,74,0)"/>
    </radialGradient>
    <radialGradient id="mist3" cx="50%" cy="60%" r="40%">
      <stop offset="0%" stop-color="rgba(232,224,208,0.04)"/>
      <stop offset="100%" stop-color="rgba(232,224,208,0)"/>
    </radialGradient>
    <filter id="blur"><feGaussianBlur stdDeviation="20"/></filter>
  </defs>
  <rect width="750" height="300" fill="transparent"/>
  <ellipse cx="225" cy="150" rx="200" ry="120" fill="url(#mist1)" filter="url(#blur)"/>
  <ellipse cx="525" cy="120" rx="180" ry="100" fill="url(#mist2)" filter="url(#blur)"/>
  <ellipse cx="375" cy="180" rx="160" ry="90" fill="url(#mist3)" filter="url(#blur)"/>
</svg>
