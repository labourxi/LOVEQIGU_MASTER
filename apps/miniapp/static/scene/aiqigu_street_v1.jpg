<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 750 1624" width="750" height="1624">
  <defs>
    <linearGradient id="skyGrad" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#0A1A14"/>
      <stop offset="35%" stop-color="#0E221A"/>
      <stop offset="65%" stop-color="#12281F"/>
      <stop offset="100%" stop-color="#0A1A14"/>
    </linearGradient>
    <radialGradient id="pathLight" cx="50%" cy="85%" r="40%">
      <stop offset="0%" stop-color="rgba(200,162,74,0.08)"/>
      <stop offset="50%" stop-color="rgba(200,162,74,0.02)"/>
      <stop offset="100%" stop-color="rgba(200,162,74,0)"/>
    </radialGradient>
    <filter id="fog"><feGaussianBlur stdDeviation="4"/></filter>
  </defs>
  <rect width="750" height="1624" fill="url(#skyGrad)"/>
  <!-- Buildings/walls along street -->
  <g opacity="0.06" filter="url(#fog)">
    <rect x="0" y="920" width="120" height="300" rx="2" fill="#1A2E22"/>
    <rect x="620" y="960" width="130" height="260" rx="2" fill="#1A3024"/>
  </g>
  <g opacity="0.08">
    <rect x="100" y="1000" width="100" height="220" rx="2" fill="#1E3628"/>
    <rect x="530" y="1020" width="110" height="200" rx="2" fill="#1E3628"/>
  </g>
  <!-- Street/path surface -->
  <path d="M200 1080 Q375 1060 550 1080 L600 1150 Q375 1120 150 1150Z" fill="#142E24" opacity="0.3"/>
  <!-- Path extending inward -->
  <path d="M300 1080 Q375 1060 450 1080 L480 1200 Q375 1160 270 1200Z" fill="#0E221A" opacity="0.2"/>
  <!-- Gold light source ahead -->
  <ellipse cx="375" cy="1000" rx="80" ry="60" fill="rgba(200,162,74,0.04)" filter="url(#fog)"/>
  <rect x="0" y="900" width="750" height="500" fill="url(#pathLight)"/>
  <rect x="0" y="1400" width="750" height="224" fill="#0A1A14" opacity="0.5"/>
</svg>
