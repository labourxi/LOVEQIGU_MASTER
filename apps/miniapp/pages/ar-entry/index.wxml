<view class="ar-entry-page">
  <view class="ui-overlay-layer ar-entry-ui">
    <!-- ─── XR SAFE MODE 占位UI ─── -->
    <view wx:if="{{markerUi.xrSafeMode}}" class="xr-safe-mode-banner">
      <view class="xr-safe-mode-banner__icon">🛡️</view>
      <view class="xr-safe-mode-banner__title">XR 安全模式</view>
      <view class="xr-safe-mode-banner__desc">3D 资源加载异常，已切换至基础浏览模式</view>
      <view class="xr-safe-mode-banner__reason">原因：{{markerUi.xrSafeModeReason}}</view>
    </view>

    <!-- ─── 返回按钮 ─── -->
    <view class="ar-entry-topbar">
      <button class="ar-entry-back proto-btn proto-btn--ghost" bindtap="onReturnHome">返回</button>
    </view>

    <!-- ─── 卡1：主行动按钮区 ─── -->
    <view class="ar-card-stack">
      <view class="ar-hero-card">
        <view class="ar-hero-card__label">AR 显现</view>
        <view class="ar-hero-card__title">{{detail ? detail.point_name : '选择探索点'}}</view>
        <view class="ar-hero-card__desc">将设备对准识别图，信物将在空间中显现</view>
        <button class="ar-hero-card__action proto-btn proto-btn--float" bindtap="onEnterARScan">
          开始显现
        </button>
        <view class="ar-hero-card__aura"></view>
      </view>

      <!-- ─── 卡2：XR 区域 — 渐变 + 模拟深度光 ─── -->
      <view class="ar-xr-aura-card">
        <view class="ar-xr-aura-card__label">扫描空间</view>
        <view class="ar-xr-aura-card__surface">
          <view class="ar-xr-aura-card__glow"></view>
          <view class="ar-xr-aura-card__ring"></view>
          <view wx:if="{{pilotSceneActive}}" class="ar-xr-aura-card__hint">{{pilotSceneHint}}</view>
        </view>
        <view class="ar-xr-aura-card__caption">对准识别图 · 信物将在空间中显现</view>
      </view>

      <!-- ─── 卡3：探索状态 ─── -->
      <view wx:if="{{overview && overview.stats}}" class="ar-status-card">
        <view class="ar-status-card__kicker">探索进度</view>
        <view class="ar-status-card__row">
          <text class="ar-status-card__stat">
            <text class="ar-status-card__num">{{overview.stats.completionRate}}%</text>
            <text class="ar-status-card__lbl">完成度</text>
          </text>
          <text class="ar-status-card__stat">
            <text class="ar-status-card__num">{{overview.stats.completedTaskCount}}/{{overview.stats.taskCount}}</text>
            <text class="ar-status-card__lbl">印记</text>
          </text>
        </view>
        <view class="ar-status-card__scan" wx:if="{{scanState}}">
          <text class="ar-status-card__scan-dot"></text>
          {{scanState}}
        </view>
      </view>

      <!-- ─── 卡4：信物 / 礼物 ─── -->
      <view class="ar-gift-card">
        <view class="ar-gift-card__kicker">信物 · 故事进度资产</view>
        <view class="ar-gift-card__body">
          <view class="ar-gift-card__icon">✦</view>
          <view class="ar-gift-card__text">
            <view class="ar-gift-card__title">显现后可收录至信物库</view>
            <view class="ar-gift-card__desc">完成显现流程，印记将收入你的收藏册</view>
          </view>
        </view>
      </view>

      <!-- ─── 卡5：显现引导（条件显示） ─── -->
      <view wx:if="{{runtimePocActive}}" class="ar-guide-card">
        <view class="ar-guide-card__kicker">识别引导</view>
        <view class="ar-guide-card__viewport">
          <image class="ar-guide-card__overlay" src="{{overlayPath}}" mode="aspectFit" />
        </view>
        <view class="ar-guide-card__hint">{{overlayHint}}</view>
        <view class="ar-guide-card__flow" wx:if="{{runtimeFlowStages.length}}">
          <text wx:for="{{runtimeFlowStages}}" wx:for-item="s" wx:key="stage" class="ar-guide-card__step">
            <text class="ar-guide-card__step-dot"></text>{{s.stage}}
          </text>
        </view>
      </view>

      <!-- ─── 卡6：引导提示（含主副按钮） ─── -->
      <view class="ar-action-card">
        <view class="ar-action-card__label">显现提示</view>
        <view class="ar-action-card__hint">{{scanHint}}</view>
        <view wx:if="{{revelationMessage}}" class="ar-action-card__revelation">{{revelationMessage}}</view>
        <view wx:if="{{bridgeMode}}" class="ar-action-card__mode">
          {{bridgeMode === 'FALLBACK' ? '备用显现' : 'AR 显现'}}
        </view>
        <button class="proto-btn proto-btn--primary ar-action-card__btn"
                bindtap="onPrimaryAction"
                disabled="{{primaryDisabled}}">
          {{primaryLabel}}
        </button>
        <button wx:if="{{showSecondary}}"
                class="proto-btn proto-btn--ghost ar-action-card__btn ar-action-card__btn--sec"
                bindtap="onSecondaryAction">
          {{secondaryLabel}}
        </button>
      </view>
    </view>

    <user-bottom-nav activeKey="{{activeTab}}" bind:change="onBottomNavChange" />
    <pilot-fx-overlay id="pilotFx" />
  </view>
</view>
