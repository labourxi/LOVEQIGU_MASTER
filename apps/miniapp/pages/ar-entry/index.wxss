@import '../../styles/prototype-v1.wxss';
@import '../../styles/xr-ui-overlay.wxss';

.ar-entry-page {
  background: #f4f1eb;
}

.ar-entry-marker-ui--host {
  top: 0;
  height: 520rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, rgba(31, 42, 38, 0.72) 0%, rgba(31, 42, 38, 0.35) 55%, rgba(31, 42, 38, 0.72) 100%);
  box-sizing: border-box;
}

.ar-entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #f4f1eb;
}

.ar-entry-copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(244, 241, 235, 0.82);
}

.ar-entry-btn {
  margin-top: 20rpx;
  pointer-events: auto;
}

.ar-entry-row {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: rgba(244, 241, 235, 0.9);
}

.xr-host-layer--ar-entry ar-marker-entry,
.xr-host-layer--ar-entry ar-marker-xr-scene {
  display: block;
  width: 100%;
  height: 100%;
}

.ar-entry-xr-spacer {
  height: 520rpx;
  margin-top: 0;
  padding: 0;
  background: transparent;
}

.ar-entry-ui {
  padding-bottom: 160rpx;
}

.ar-entry-topbar {
  position: relative;
  z-index: 20;
  padding: 8rpx 0 0;
  pointer-events: auto;
}

.ar-entry-back {
  width: auto;
  min-width: 140rpx;
}

.ar-scan-card {
  overflow: hidden;
}

.ar-scan-viewport {
  position: relative;
  width: 100%;
  height: 480rpx;
  margin: 24rpx 0;
  background: #1f2a26;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ar-scan-overlay {
  width: 78%;
  height: 78%;
  opacity: 0.72;
}
