.ar-scan-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

.ar-scan-viewport {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ar-scan-viewport__label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 40rpx;
}

.ar-scan-viewport__frame {
  width: 480rpx;
  height: 480rpx;
  border: 2rpx solid rgba(200, 162, 74, 0.2);
  border-radius: 16rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ar-scan-viewport__frame--scanning {
  border-color: rgba(200, 162, 74, 0.3);
  animation: ar-scan-pulse 2s ease-in-out infinite;
}

@keyframes ar-scan-pulse {
  0%, 100% { border-color: rgba(200, 162, 74, 0.2); }
  50% { border-color: rgba(200, 162, 74, 0.5); }
}

.ar-scan-viewport__scanner {
  width: 200rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #C8A24A, transparent);
  animation: ar-scan-line 2s ease-in-out infinite;
  position: absolute;
  top: 30%;
}

@keyframes ar-scan-line {
  0% { top: 20%; opacity: 0.3; }
  50% { top: 60%; opacity: 0.8; }
  100% { top: 20%; opacity: 0.3; }
}

.ar-scan-viewport__frame--success {
  border-color: rgba(200, 162, 74, 0.3);
}

.ar-scan-viewport__check {
  font-size: 72rpx;
  color: rgba(200, 162, 74, 0.4);
}

.ar-scan-viewport__frame--error {
  border-color: rgba(180, 80, 60, 0.2);
}

.ar-scan-viewport__error-icon {
  font-size: 72rpx;
  color: rgba(180, 80, 60, 0.3);
}

.ar-scan-viewport__hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.15);
  margin-top: 32rpx;
  letter-spacing: 3rpx;
}

.ar-scan-viewport__hint--error {
  color: rgba(180, 80, 60, 0.3);
}

.ar-scan-close {
  position: absolute;
  top: 80rpx;
  right: 32rpx;
  padding: 16rpx 32rpx;
}

.ar-scan-close__text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  letter-spacing: 2rpx;
}
