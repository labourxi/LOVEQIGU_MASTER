<view class="page home-shell">
  <view class="home-shell-header">
    <home-mode-switch
      activeMode="{{activeMode}}"
      showCampaignTab="{{showCampaignTab}}"
      bind:change="onModeChange"
    />
  </view>

  <campaign-mode-banner campaign="{{campaign}}" />

  <view class="policy-debug" wx:if="{{false}}">
    <text>home_policy: {{policy.home_policy}}</text>
    <text>default_mode: {{policy.default_mode}}</text>
    <text>forced_mode: {{policy.forced_mode}}</text>
    <text>experiment_group: {{policy.experiment_group}}</text>
  </view>

  <view class="home-shell-body home-shell-body--explore" wx:if="{{activeMode === 'explore'}}">
    <explore-home-panel panel="{{explore}}" bind:navigate="onNavigate" />
  </view>

  <view class="home-shell-body home-shell-body--affinity" wx:elif="{{activeMode === 'affinity'}}">
    <affinity-home-panel panel="{{affinity}}" bind:navigate="onNavigate" />
  </view>

  <view class="home-shell-body home-shell-body--campaign" wx:elif="{{activeMode === 'campaign'}}">
    <campaign-home-panel panel="{{campaign}}" />
  </view>

  <view class="home-shell-footer">
    <view class="footer-note">双模式首页 · 探索与权益切换</view>
  </view>
</view>
