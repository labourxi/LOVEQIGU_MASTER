<view class="v54-page v55-aware--{{awarenessMode}}">

  <!-- ─── 背景氛围层 ─── -->
  <view class="v54-atmosphere v55-atmosphere--{{awarenessMode}}">
    <view class="v54-atmosphere__mist"></view>
    <view class="v54-atmosphere__glow"></view>
    <view class="v54-atmosphere__fog"></view>
  </view>
  <view class="v55-atmosphere-particle v55-particle--{{awarenessMode}}"></view>

  <!-- ─── 记忆共鸣场 ─── -->
  <view class="v55-resonance-field v55-field--{{awarenessMode}}"></view>

  <!-- ─── 显象流 — 世界回应氛围 ─── -->
  <view class="v55-apparition-overlay v55-apparition--{{awarenessMode}}"></view>

  <!-- ─── 骨架加载 ─── -->
  <view wx:if="{{loading}}" class="v54-skeleton">
    <view class="v54-skeleton__hero"></view>
    <view class="v54-skeleton__card"></view>
    <view class="v54-skeleton__card"></view>
    <view class="v54-skeleton__card"></view>
  </view>

  <block wx:else>

    <!-- ════════════════════════════════════
         BLOCK 1: WORLD MANIFEST
         Arrival moment — the world receives you
         ════════════════════════════════════ -->
    <view class="v55-manifest">
      <view class="v55-manifest__seal">
        <text class="v55-manifest__seal-char">爱</text>
      </view>
      <view class="v55-manifest__realm">游离之域</view>
      <view class="v55-manifest__whisper">{{scenicLayers.worldState.worldHint}}</view>
      <view class="v55-manifest__atmosphere">{{scenicLayers.worldState.atmosphere}}</view>

      <!-- 记忆低语 — 返回访问时 -->
      <view wx:if="{{memoryDialogue}}" class="v55-memory-dialogue">{{memoryDialogue}}</view>

      <!-- 世界记忆网络低语 -->
      <view wx:if="{{showNetworkMurmur}}" class="v55-network-murmur">{{networkMurmur}}</view>
    </view>

    <!-- ════════════════════════════════════
         BLOCK 2: EXPLORE ENTRY
         Single primary entry point to the world
         ════════════════════════════════════ -->
    <view class="v55-explore-entry" bindtap="onOpenExploreMap">
      <view class="v55-explore-entry__icon">
        <text class="v55-explore-entry__glyph">◎</text>
      </view>
      <view class="v55-explore-entry__body">
        <view class="v55-explore-entry__name">路径正在显现</view>
        <view class="v55-explore-entry__desc">跟随星点的指引</view>
      </view>
      <view class="v55-explore-entry__action">回应</view>
    </view>

    <!-- ════════════════════════════════════
         BLOCK 3: FOCUS POINT — 爱企谷入口广场
         Visually dominant hero card, primary CTA only
         ════════════════════════════════════ -->
    <view wx:if="{{showJourney}}" class="v55-journey v55-journey--{{resonanceFieldClass}} v55-journey--{{awarenessMode}}">
      <view
        class="v55-hero-card v55-hero-card--{{awarenessMode}}"
        data-point-id="{{scenicLayers.heroItem.point_id}}"
        bindtap="onOpenPointDetail"
      >
        <view class="v55-hero-card__glow"></view>
        <view class="v55-hero-card__halo"></view>
        <view class="v55-hero-card__body">
          <view class="v55-hero-card__place-label">爱企谷·入口广场</view>
          <view class="v55-hero-card__name">{{scenicLayers.heroItem.phenomenon}}</view>
          <view class="v55-hero-card__emotion">“{{scenicLayers.heroItem.emotion}}”</view>
        </view>
        <view class="v55-hero-card__action">回应</view>
      </view>

      <!-- ─── SECONDARY POINTS (indices 1-3) ─── -->
      <view class="v55-journey__secondary">
        <view
          class="v55-secondary-card v55-secondary-card--{{awarenessMode}}"
          wx:for="{{scenicLayers.secondaryItems}}"
          wx:key="point_id"
          data-point-id="{{item.point_id}}"
          bindtap="onOpenPointDetail"
          style="animation-delay: {{item.staggerDelay}}ms;"
        >
          <view class="v55-secondary-card__body">
            <view class="v55-secondary-card__icon">◈</view>
            <view class="v55-secondary-card__text">
              <view class="v55-secondary-card__name">{{item.phenomenon}}</view>
              <view class="v55-secondary-card__emotion">“{{item.emotion}}”</view>
            </view>
            <view class="v55-secondary-card__action">回应</view>
          </view>
        </view>
      </view>

      <!-- ─── BACKGROUND CONTEXT (indices 4-9) ─── -->
      <view class="v55-journey__context">
        <view class="v55-journey__context-fade"></view>
        <view
          class="v55-context-card v55-context-card--{{awarenessMode}}"
          wx:for="{{scenicLayers.contextItems}}"
          wx:key="point_id"
          data-point-id="{{item.point_id}}"
          bindtap="onOpenPointDetail"
          style="animation-delay: {{item.staggerDelay}}ms;"
        >
          <view class="v55-context-card__body">
            <view class="v55-context-card__name">{{item.phenomenon}}</view>
          </view>
        </view>
      </view>

    </view>
    <view wx:else class="v55-scenic-fallback">
      <text>世界正在加载...</text>
    </view>

    <!-- ════════════════════════════════════
         BLOCK 4: RELIC MANIFESTATION
         Phenomena that occur in the world
         ════════════════════════════════════ -->

    <!-- Manifestation Sequence Overlay -->
    <view wx:if="{{showManifestationOverlay}}" class="v55-manifestation-overlay">
      <view class="v55-manifestation-dim" style="opacity: {{manifestationDim}};"></view>
      <view class="v55-manifestation-mist" style="opacity: {{manifestationMist}};"></view>
      <view wx:if="{{manifestationPauseActive}}" class="v55-manifestation-pulse"></view>
    </view>

    <!-- Manifested Relics -->
    <view wx:if="{{manifestationActive && manifestedEvents.length > 0}}" class="v55-phenomenon-block">
      <view class="v55-phenomenon-block__header">
        <view class="v55-phenomenon-block__title">显现</view>
        <view class="v55-phenomenon-block__count">{{manifestedEvents.length}} 段记忆</view>
      </view>

      <view
        class="v55-phenomenon-item v55-phenomenon-item--{{item.intensity}} v55-phenomenon-item--{{awarenessMode}} {{item.temporalClass}}
          {{item.temporalPulseClass}}
          {{item.temporalWarmShiftClass}}"
        wx:for="{{manifestedEvents}}"
        wx:key="id"
        style="opacity: {{item.temporalOpacity}}; transition: opacity 0.8s ease; filter: blur({{item.temporalBlur}}rpx);"
      >
        <view class="v55-phenomenon-item__aura"
          style="background: radial-gradient(circle, {{item.color}}18 0%, transparent 70%); opacity: {{item.temporalGlowOpacity}};">
        </view>
        <view class="v55-phenomenon-item__body">
          <view class="v55-phenomenon-item__symbol">{{item.symbol}}</view>
          <view class="v55-phenomenon-item__content">
            <view class="v55-phenomenon-item__name">{{item.phenomenon}}</view>
            <view class="v55-phenomenon-item__emotion">“{{item.emotion}}”</view>
            <view class="v55-phenomenon-item__echo">{{item.locationEcho}}</view>
            <view wx:if="{{item.timeFeedback}}" class="v55-phenomenon-item__time-feedback">{{item.timeFeedback}}</view>
          </view>
        </view>
      </view>
    </view>

  </block>

  <pilot-fx-overlay id="pilotFx" />
  <user-bottom-nav activeKey="{{activeTab}}" bind:change="onBottomNavChange" />
</view>