.home-page {
  padding-top: 24rpx;
}

.hero {
  position: relative;
  height: 560rpx;
  overflow: hidden;
  border-radius: 0 0 24rpx 24rpx;
  background: #1b1f25;
}

.hero-image,
.hero-shade {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-shade {
  background: linear-gradient(90deg, rgba(12, 18, 24, 0.82), rgba(12, 18, 24, 0.28));
}

.hero-content {
  position: relative;
  z-index: 1;
  width: 74%;
  box-sizing: border-box;
  padding: 64rpx 36rpx;
  color: #ffffff;
}

.hero-kicker {
  color: #d6c08d;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1.2;
}

.hero-copy {
  margin-top: 18rpx;
  max-width: 500rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 28rpx;
  line-height: 1.5;
}

.hero-button,
.quick-card {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: normal;
  text-align: left;
}

.hero-button::after,
.quick-card::after {
  border: 0;
}

.hero-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 184rpx;
  height: 72rpx;
  margin-top: 34rpx;
  border-radius: 36rpx;
  background: #d6c08d;
  color: #15171c;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

.chapter-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.panel-label,
.panel-status {
  color: #7f4f24;
  font-size: 22rpx;
  font-weight: 700;
}

.panel-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.panel-status {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #e8d8b4;
  white-space: nowrap;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.stat-item,
.notice-item,
.quick-card {
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.stat-item {
  padding: 26rpx 18rpx;
}

.stat-value {
  color: #7f4f24;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.section {
  margin-top: 40rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  display: flex;
  min-height: 128rpx;
  box-sizing: border-box;
  padding: 20rpx;
}

.quick-label {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.quick-hint {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.notice-item {
  padding: 22rpx;
}

.notice-title {
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
}

.notice-desc {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 23rpx;
  line-height: 1.45;
}
