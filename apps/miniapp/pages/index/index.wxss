.home-shell {
  padding-top: 24rpx;
}

.home-shell-header {
  position: sticky;
  top: 0;
  z-index: 10;
  margin-bottom: 24rpx;
}

.home-shell-body {
  display: flex;
  flex-direction: column;
}

.home-shell-body--explore {
  gap: 0;
}

.home-shell-body--affinity {
  gap: 0;
}

.home-shell-footer {
  margin-top: 36rpx;
  padding-bottom: 12rpx;
}

.footer-note {
  color: #9ca3af;
  font-size: 22rpx;
  text-align: center;
}

.policy-debug {
  display: none;
}
