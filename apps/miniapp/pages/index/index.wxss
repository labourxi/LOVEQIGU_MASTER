@import '../../styles/prototype-v1.wxss';
@import '../../styles/user-phase1.wxss';
@import '../../styles/experience-animations-v54.wxss';

.user-home-page {
  padding-top: 0;
}

.login-panel,
.summary-card {
  padding: 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.05);
}

.login-panel {
  margin-top: 22rpx;
  background: #faf8f4;
  border: 1rpx solid rgba(15, 42, 34, 0.06);
}

.login-panel--logged {
  border-color: rgba(182, 138, 61, 0.2);
}

.panel-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.panel-title {
  color: #0F2A22;
  font-size: 30rpx;
  font-weight: 700;
}

.panel-copy {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.panel-badge {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e8d8b4;
  color: #6b4220;
  font-size: 20rpx;
  font-weight: 700;
}

.primary-button {
  margin-top: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #0F2A22;
  color: #C8A24A;
  font-size: 28rpx;
  font-weight: 700;
}

.primary-button::after {
  border: 0;
}

.home-skeleton {
  padding: 24rpx 0 40rpx;
}

.home-skeleton__block,
.home-skeleton__pill {
  background: linear-gradient(90deg, #ece8e0 25%, #f5f2ec 50%, #ece8e0 75%);
  background-size: 200% 100%;
  animation: home-skeleton-shimmer 1.2s ease-in-out infinite;
  border-radius: 16rpx;
}

.home-skeleton__hero {
  height: 280rpx;
  margin-bottom: 24rpx;
}

.home-skeleton__row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.home-skeleton__pill {
  flex: 1;
  height: 96rpx;
  border-radius: 999rpx;
}

.home-skeleton__cta {
  height: 88rpx;
  margin-bottom: 16rpx;
}

.home-skeleton__panel {
  height: 160rpx;
  margin-bottom: 16rpx;
}

@keyframes home-skeleton-shimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

