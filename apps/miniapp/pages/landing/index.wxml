<!--
  PAGE_01_LANDING — 爱企谷首页 (Aigugu World Entry Page)

  V7 CIVILIZATION OS — AIGU VALLEY WORLD ENTRY PAGE

  CRITICAL DESIGN RULES:
    1. ready gates ALL UI — skeleton shows until store data is bound
    2. IMAGES ARE NON-BLOCKING — safe <image> wrapper with binderror
    3. UI renders ONLY when ready=true (store populated)
    4. No image dependency on entry system or render completion

  ASSET RULES:
    - /images/ path prefix (canonical)
    - Safe <image> component for error handling
    - CSS background-image ALSO set for depth, but non-blocking
    - onImgError handler sets fallback image

  LOGIN BUTTON:
    - Single fixed-bottom overlay
    - Gated by loginVisible (from store.userState.isGuest)
    - Independent of image load state
-->

<view class="lp-page" data-world-mode="{{worldMode}}">

  <!-- ─── 骨架加载 (until ready) ─── -->
  <view wx:if="{{!ready}}" class="lp-skeleton">
    <view class="lp-skeleton__bg"></view>
    <view class="lp-skeleton__title"></view>
    <view class="lp-skeleton__stats"></view>
    <view class="lp-skeleton__cta"></view>
  </view>

  <block wx:else>

    <!-- ════════════════════════════════════════════════════════════
         LAYER 1: BACKGROUND SCENE
         NON-BLOCKING: safe <image> wrapper + CSS background fallback
         ════════════════════════════════════════════════════════════ -->
    <view class="lp-bg">
      <!-- V3 定稿设计图作为全幅背景 -->
      <image wx:if="{{bgImage}}"
        class="lp-bg__image"
        src="{{bgImage}}"
        binderror="onImgError"
        mode="scaleToFill"
      ></image>
      <!-- CSS gradient fallback -->
      <view wx:if="{{!bgImage}}"
        class="lp-bg__scene lp-bg__scene--gradient">
      </view>
    </view>

    <!-- ════════════════════════════════════════════════════════════
         LAYER 2-5: V3 DESIGN COVER — 设计图已包含这些 UI，
         将 WXML 视觉层透明化，仅保留不可见的交互点击区域
         ════════════════════════════════════════════════════════════ -->
    <view class="v3-design-cover">
      <view class="lp-intro">
        <view class="lp-intro__portal">
          <view class="lp-intro__ring"></view>
          <view class="lp-intro__core"></view>
          <view class="lp-intro__particles"></view>
        </view>
        <view class="lp-intro__title">爱企谷</view>
        <view class="lp-intro__roman">AIGU VALLEY</view>
        <view class="lp-intro__verse">游离之域 · 世界正在显现</view>
      </view>

      <view class="lp-stats">
        <view class="lp-stats__grid">
          <view class="lp-stat-card">
            <view class="lp-stat-card__value">{{stats.explorationCount}}</view>
            <view class="lp-stat-card__label">探索点已启</view>
          </view>
          <view class="lp-stat-card">
            <view class="lp-stat-card__value">{{stats.relicCount}}</view>
            <view class="lp-stat-card__label">信物已得</view>
          </view>
          <view class="lp-stat-card">
            <view class="lp-stat-card__value">{{stats.couponCount}}</view>
            <view class="lp-stat-card__label">权益已领</view>
          </view>
          <view class="lp-stat-card">
            <view class="lp-stat-card__value">{{stats.progress}}%</view>
            <view class="lp-stat-card__label">探索进度</view>
          </view>
        </view>
      </view>
    </view>

    <!-- ════════════════════════════════════════════════════════════
         LAYER 4: EXPLORATION CAROUSEL — 设计图上无，保留可见
         ════════════════════════════════════════════════════════════ -->
    <view class="lp-carousel-wrap">
      <view class="lp-carousel-label">十个世界节点</view>
      <scroll-view class="lp-carousel" scroll-x="true" enhanced-show-scrollbar="{{false}}">
        <view
          class="lp-carousel__item lp-carousel__item--{{item.status}}"
          wx:for="{{carouselItems}}"
          wx:key="id"
          data-index="{{index}}"
          data-id="{{item.id}}"
          bindtap="onCarouselTap"
        >
          <view class="lp-carousel__dot" style="background: {{item.themeColor}};"></view>
          <view class="lp-carousel__name">{{item.name}}</view>
          <view class="lp-carousel__subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
          <view class="lp-carousel__region" wx:if="{{item.region}}">{{item.region}}</view>
          <view class="lp-carousel__status">{{item.statusLabel}}</view>
        </view>
      </scroll-view>
    </view>

    <!-- ════════════════════════════════════════════════════════════
         LAYER 5: SECONDARY CTA (logged-in users)
         V3 设计图模式：也透明化，入口仅通过登录按钮
         ════════════════════════════════════════════════════════════ -->
    <view class="v3-design-cover">
    <block wx:if="{{userType !== 'guest'}}">
      <view class="lp-actions">
        <button class="lp-cta lp-cta--primary" bindtap="onEnterExplore">
          <text class="lp-cta__label">进入探索</text>
        </button>
        <view class="lp-cta__hint">{{userType === 'active_explorer' ? '新信物正在等待显现' : '进入AR游伴探索世界'}}</view>
      </view>
    </block>
    </view>

  </block>
</view>

<!-- ─── P0: 微信一键登录 — 固定底部覆盖层 ───
     Gated by ready. NEVER blocked by assets. -->
<block wx:if="{{ready && loginVisible !== false}}">
  <view class="lp-login-fixed">
    <button class="lp-login-fixed__btn {{!agreeProtocol ? 'lp-login-fixed__btn--disabled' : ''}}" bindtap="onWechatLogin" disabled="{{!agreeProtocol}}">
      <text class="lp-login-fixed__icon"></text>
      <text class="lp-login-fixed__label">微信一键登录</text>
    </button>
    <!-- WORLD LANDING PAGE V3: 协议勾选区 -->
    <view class="lp-login-fixed__agreement">
      <view class="lp-agreement-row">
        <view class="lp-agreement-checkbox" bindtap="onToggleAgreement">
          <view wx:if="{{agreeProtocol}}" class="lp-agreement-checkbox__checked"></view>
        </view>
        <text class="lp-agreement-text">我已阅读并同意</text>
      </view>
      <view class="lp-agreement-links">
        <text class="lp-agreement-link" bindtap="onTapUserAgreement">《用户协议》</text>
        <text class="lp-agreement-link lp-agreement-link--sep"> </text>
        <text class="lp-agreement-link" bindtap="onTapPrivacyPolicy">《隐私政策》</text>
      </view>
    </view>
    <view wx:if="{{!agreeProtocol}}" class="lp-login-fixed__hint">请先阅读并同意协议</view>
  </view>
</block>
