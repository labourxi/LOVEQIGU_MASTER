/* ═══════════════════════════════════════════════════════════════════
   PAGE_01_LANDING — V3 DESIGN MODE

   V3 设计图包含全部视觉。CSS 仅控制：
     - 背景图铺满（aspectFill）
     - 登录按钮透明热区
     - checkbox + 协议链接样式
   ═══════════════════════════════════════════════════════════════════ */

/* ─── PAGE CONTAINER ─── */
.lp-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  height: 100dvh;
  background: #0A1A14;
  overflow: hidden;
}

/* ═══ BACKGROUND: 设计图全幅 ═══ */
.lp-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.lp-bg__image {
  width: 100%;
  height: 100%;
  display: block;
}

/* ═══ LOGIN FIXED: 透明点击热区 + 协议 ═══ */
.lp-login-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

/* 透明按钮热区 — 覆盖设计图的登录按钮位置 */
.lp-login-fixed__btn {
  width: 480rpx;
  height: 100rpx;
  margin-bottom: 10rpx;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  pointer-events: auto;
  position: relative;
}

/* 按钮热区可点击区域扩大 */
.lp-login-fixed__btn::after {
  content: '';
  position: absolute;
  inset: -20rpx;
}

/* 禁用态 */
.lp-login-fixed__btn--disabled {
  opacity: 0 !important;
  pointer-events: none;
}

/* ═══ AGREEMENT — 金色高亮 ═══ */
.lp-login-fixed__agreement {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  pointer-events: auto;
  padding: 14rpx 48rpx;
}

.lp-agreement-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.lp-agreement-checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid #C8A24A;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(200, 162, 74, 0.08);
  transition: all 0.2s ease;
}

.lp-agreement-checkbox:active {
  background: rgba(200, 162, 74, 0.2);
}

.lp-agreement-checkbox__checked {
  width: 20rpx;
  height: 20rpx;
  border-radius: 3rpx;
  background: #C8A24A;
  position: relative;
}

.lp-agreement-checkbox__checked::after {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 2rpx;
  width: 8rpx;
  height: 14rpx;
  border: solid #0A1A14;
  border-width: 0 2.5rpx 2.5rpx 0;
  transform: rotate(45deg);
}

.lp-agreement-text {
  font-size: 24rpx;
  color: #C8A24A;
  letter-spacing: 2rpx;
  font-weight: 400;
}

.lp-agreement-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.lp-agreement-link {
  font-size: 24rpx;
  color: #C8A24A;
  letter-spacing: 2rpx;
  font-weight: 400;
  text-decoration: underline;
  text-decoration-color: rgba(200, 162, 74, 0.3);
}

.lp-agreement-link:active {
  color: #D4B86A;
}

.lp-login-fixed__hint {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: rgba(200, 162, 74, 0.5);
  letter-spacing: 4rpx;
  font-weight: 300;
  pointer-events: auto;
}
