/* ═══════════════════════════════════════════════════════════════════
   PAGE_01_LANDING — V3 DESIGN MODE

   V3 设计图包含全部视觉。CSS 仅控制：
     - 背景图铺满（aspectFill）
     - 登录按钮透明热区
     - checkbox + 协议链接样式
   ═══════════════════════════════════════════════════════════════════ */

/* ─── PAGE CONTAINER ─── */
.lp-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  height: 100dvh;
  background: #0A1A14;
  overflow: hidden;
}

/* ═══ BACKGROUND: 设计图全幅 ═══ */
.lp-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.lp-bg__image {
  width: 100%;
  height: 100%;
  display: block;
}

/* ═══ LOGIN FIXED: 透明点击热区 + 协议 ═══ */
.lp-login-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

/* 透明按钮热区 — 覆盖设计图的登录按钮位置 */
.lp-login-fixed__btn {
  width: 480rpx;
  height: 100rpx;
  margin-bottom: 10rpx;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  pointer-events: auto;
  position: relative;
}

/* 按钮热区可点击区域扩大 */
.lp-login-fixed__btn::after {
  content: '';
  position: absolute;
  inset: -20rpx;
}

/* 禁用态 */
.lp-login-fixed__btn--disabled {
  opacity: 0 !important;
  pointer-events: none;
}

/* ═══ AGREEMENT ═══ */
.lp-login-fixed__agreement {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  pointer-events: auto;
  padding: 10rpx 48rpx;
}

.lp-agreement-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.lp-agreement-checkbox {
  width: 28rpx;
  height: 28rpx;
  border-radius: 4rpx;
  border: 1.5rpx solid rgba(200, 162, 74, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.lp-agreement-checkbox:active {
  border-color: rgba(200, 162, 74, 0.5);
}

.lp-agreement-checkbox__checked {
  width: 18rpx;
  height: 18rpx;
  border-radius: 2rpx;
  background: #C8A24A;
  position: relative;
}

.lp-agreement-checkbox__checked::after {
  content: '';
  position: absolute;
  left: 5rpx;
  top: 2rpx;
  width: 8rpx;
  height: 12rpx;
  border: solid #0A1A14;
  border-width: 0 2rpx 2rpx 0;
  transform: rotate(45deg);
}

.lp-agreement-text {
  font-size: 20rpx;
  color: rgba(232, 224, 208, 0.25);
  letter-spacing: 2rpx;
  font-weight: 300;
}

.lp-agreement-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.lp-agreement-link {
  font-size: 20rpx;
  color: rgba(200, 162, 74, 0.35);
  letter-spacing: 2rpx;
  font-weight: 300;
  text-decoration: underline;
  text-decoration-color: rgba(200, 162, 74, 0.15);
}

.lp-agreement-link:active {
  color: rgba(200, 162, 74, 0.6);
}

.lp-login-fixed__hint {
  margin-top: 12rpx;
  font-size: 18rpx;
  color: rgba(232, 224, 208, 0.2);
  letter-spacing: 4rpx;
  font-weight: 300;
  pointer-events: auto;
}
