/* ═══════════════════════════════════
   Landing Page V3 — 仪式入口（DESIGN FREEZE）
   水墨 / 雾山 / 光流
   LOCKED Colors: #0F2A22 / #F3F0E8 / #C8A24A
   禁止原生微信按钮 / 卡片式 / 工具风
   ═══════════════════════════════════ */

.landing-page {
  position: relative;
  min-height: 100vh;
  background: #0F2A22;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* ─── 背景系统：水墨雾山光流 ─── */
.landing-atmosphere {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

/* 雾底 */
.landing-atmosphere__mist {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg,
    rgba(26, 44, 38, 1) 0%,
    rgba(38, 58, 52, 0.92) 40%,
    rgba(38, 58, 52, 0.88) 70%,
    rgba(26, 44, 38, 0.95) 100%
  );
}

/* 山形（CSS 模拟水墨山） */
.landing-atmosphere__mountain {
  position: absolute;
  bottom: 0;
  left: -20%;
  right: -20%;
  height: 45%;
  background:
    radial-gradient(ellipse 120% 100% at 20% 100%, rgba(30, 48, 42, 0.6) 0%, transparent 70%),
    radial-gradient(ellipse 100% 80% at 60% 100%, rgba(35, 55, 48, 0.4) 0%, transparent 60%),
    radial-gradient(ellipse 80% 90% at 85% 100%, rgba(28, 46, 40, 0.5) 0%, transparent 65%);
}

/* 光流 */
.landing-atmosphere__lightflow {
  position: absolute;
  top: 10%;
  left: 50%;
  transform: translateX(-50%);
  width: 500rpx;
  height: 400rpx;
  background:
    radial-gradient(ellipse at 50% 0%, rgba(200, 162, 74, 0.06) 0%, transparent 60%),
    radial-gradient(ellipse at 50% 100%, rgba(200, 162, 74, 0.03) 0%, transparent 50%);
  animation: landing-lightflow 8s ease-in-out infinite;
}

@keyframes landing-lightflow {
  0%, 100% { opacity: 0.5; transform: translateX(-50%) scaleY(1); }
  50% { opacity: 0.9; transform: translateX(-50%) scaleY(1.15); }
}

/* 雾粒子 */
.landing-atmosphere__fog {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 40%, rgba(255, 255, 255, 0.015) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 60%, rgba(255, 255, 255, 0.01) 0%, transparent 40%);
}

/* ─── 骨架 ─── */
.landing-skeleton {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.landing-skeleton__seal {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: rgba(200, 162, 74, 0.06);
  animation: landing-shimmer 2s ease-in-out infinite;
}

.landing-skeleton__title {
  width: 200rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.04);
  animation: landing-shimmer 2s ease-in-out infinite 0.3s;
}

.landing-skeleton__verse {
  width: 400rpx;
  height: 28rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.03);
  animation: landing-shimmer 2s ease-in-out infinite 0.6s;
}

.landing-skeleton__btn {
  width: 320rpx;
  height: 96rpx;
  border-radius: 16rpx;
  background: rgba(200, 162, 74, 0.04);
  animation: landing-shimmer 2s ease-in-out infinite 0.9s;
}

@keyframes landing-shimmer {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.7; }
}

/* ─── 主内容 ─── */
.landing-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding: 0 48rpx;
  box-sizing: border-box;
}

/* ─── 世界标题 + 光晕 ─── */
.landing-world-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  position: relative;
}

.landing-world-title__halo {
  position: absolute;
  top: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(200, 162, 74, 0.04) 0%, transparent 60%);
  animation: landing-halo-pulse 6s ease-in-out infinite;
}

@keyframes landing-halo-pulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.08); opacity: 1; }
}

/* 印章 */
.landing-world-title__seal {
  width: 100rpx;
  height: 100rpx;
  border: 3rpx solid rgba(200, 162, 74, 0.5);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  position: relative;
  box-shadow:
    0 0 20rpx rgba(200, 162, 74, 0.08);
}

.landing-world-title__seal-char {
  font-size: 48rpx;
  color: #C8A24A;
  font-weight: 300;
  letter-spacing: 0;
  opacity: 0.7;
}

.landing-world-title__name {
  font-size: 56rpx;
  font-weight: 700;
  color: #C8A24A;
  letter-spacing: 8rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 0 24rpx rgba(200, 162, 74, 0.12);
}

.landing-world-title__sub {
  font-size: 24rpx;
  color: rgba(200, 162, 74, 0.4);
  letter-spacing: 6rpx;
}

/* ─── 东方引导语 ─── */
.landing-guide {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 60rpx;
  width: 80%;
}

.landing-guide__line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(200, 162, 74, 0.15), transparent);
}

.landing-guide__text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 3rpx;
  text-align: center;
  white-space: nowrap;
}

/* ─── 扫码结果 ─── */
.landing-scan-badge {
  padding: 10rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(200, 162, 74, 0.08);
  color: #C8A24A;
  font-size: 22rpx;
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(200, 162, 74, 0.1);
}

/* ─── 印章化登录按钮 ─── */
.landing-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 100%;
}

.landing-seal-btn {
  position: relative;
  width: 340rpx;
  height: 100rpx;
  padding: 0;
  border: 2rpx solid rgba(200, 162, 74, 0.3);
  border-radius: 16rpx;
  background: rgba(200, 162, 74, 0.04);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow:
    0 0 16rpx rgba(200, 162, 74, 0.06);
  animation: landing-seal-breathe 4s ease-in-out infinite;
  transition: all 0.3s ease;
}

.landing-seal-btn:active {
  animation: none;
  transform: scale(0.97);
  opacity: 0.85;
}

@keyframes landing-seal-breathe {
  0%, 100% {
    box-shadow: 0 0 16rpx rgba(200, 162, 74, 0.06), 0 0 0 rgba(200, 162, 74, 0);
  }
  50% {
    box-shadow: 0 0 32rpx rgba(200, 162, 74, 0.15), 0 0 8rpx rgba(200, 162, 74, 0.05);
  }
}

.landing-seal-btn__inner {
  display: flex;
  align-items: center;
  gap: 12rpx;
  position: relative;
  z-index: 2;
}

.landing-seal-btn__char {
  font-size: 36rpx;
  color: #C8A24A;
  font-weight: 300;
  opacity: 0.8;
}

.landing-seal-btn__label {
  font-size: 26rpx;
  color: #C8A24A;
  font-weight: 600;
  letter-spacing: 6rpx;
}

.landing-seal-btn__glow {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 200rpx;
  height: 200rpx;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(200, 162, 74, 0.04) 0%, transparent 70%);
  animation: landing-glow-rotate 6s linear infinite;
  pointer-events: none;
}

@keyframes landing-glow-rotate {
  0% { transform: translate(-50%, -50%) rotate(0deg) scale(1); }
  50% { transform: translate(-50%, -50%) rotate(180deg) scale(1.2); }
  100% { transform: translate(-50%, -50%) rotate(360deg) scale(1); }
}

.landing-seal-btn::after {
  border: 0;
}

/* 幽灵按钮 — 扫码 */
.landing-ghost-btn {
  width: auto;
  height: auto;
  padding: 0;
  line-height: 1;
  background: transparent;
  border: none;
  font-size: 24rpx;
  color: rgba(200, 162, 74, 0.3);
  letter-spacing: 4rpx;
  position: relative;
}

.landing-ghost-btn::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 10%;
  right: 10%;
  height: 1rpx;
  background: rgba(200, 162, 74, 0.08);
}

.landing-ghost-btn:active {
  opacity: 0.6;
}

/* ─── 底部 ─── */
.landing-footer {
  position: absolute;
  bottom: 48rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.landing-footer__text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.1);
}

.landing-footer__dot {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.06);
}
