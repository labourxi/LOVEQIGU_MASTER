@import '../../styles/prototype-v1.wxss';
@import '../../styles/user-phase1.wxss';

.proto-row--actions {
  gap: 12rpx;
  margin-top: 16rpx;
}

.proto-row--actions .proto-btn {
  flex: 1;
}

.xr-product-entry-card {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fffaf0;
  border: 1rpx solid #ead7b0;
}

.xr-product-entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #25332b;
}

.xr-product-entry-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #677168;
}

.xr-product-entry-button {
  margin-top: 20rpx;
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  background: #213c35;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
}

.xr-product-entry-status {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #5d665f;
  word-break: break-all;
}

.xr-product-entry-ready {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #eff9f0;
  color: #2f6b39;
  font-size: 24rpx;
  line-height: 1.6;
}

.xr-product-entry-fallback {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff3e4;
  color: #9a5f00;
  font-size: 24rpx;
  line-height: 1.6;
}
