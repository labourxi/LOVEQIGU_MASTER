.sub-page {
  padding-top: 48rpx;
}

.page-title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
}

.page-desc {
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.5;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 32rpx;
}

.list-card {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.card-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.card-meta {
  margin-top: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.card-state {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #e8d8b4;
  color: #263a34;
  font-size: 22rpx;
  font-weight: 700;
}
