<view class="exp-page">
  <!-- ─── 背景：低饱和园区图 + 雾层 ─── -->
  <view class="exp-atmosphere">
    <view class="exp-atmosphere__fog"></view>
    <view class="exp-atmosphere__mist"></view>
    <view class="exp-atmosphere__glow"></view>
  </view>

  <!-- ─── 顶部：世界标题 ─── -->
  <view class="exp-header">
    <view class="exp-header__kicker">探索图谱</view>
    <view class="exp-header__title">{{activity.event_name}}</view>
    <view class="exp-header__guide">沿光点前行，印记将次第显现</view>
    <view class="exp-header__stats">
      <view class="exp-stat">
        <text class="exp-stat__value">{{stats.completedTaskCount}}</text>
        <text class="exp-stat__label">已点亮</text>
      </view>
      <view class="exp-stat">
        <text class="exp-stat__value">{{stats.ownedRelicCount}}</text>
        <text class="exp-stat__label">信物</text>
      </view>
      <view class="exp-stat">
        <text class="exp-stat__value">{{stats.claimedCouponCount}}</text>
        <text class="exp-stat__label">礼遇</text>
      </view>
    </view>
  </view>

  <!-- ─── 打卡点浮动地图 ─── -->
  <view class="exp-map">
    <view class="exp-map__title">星点路径</view>
    <view class="exp-map__trail"></view>

    <!-- 浮动节点（非列表） -->
    <view
      class="exp-node exp-node--{{item.state}}"
      wx:for="{{graphNodes}}"
      wx:key="point_id"
      data-point-id="{{item.point_id}}"
      bindtap="onOpenScanShell"
    >
      <view class="exp-node__halo"></view>
      <view class="exp-node__core">
        <view class="exp-node__dot"></view>
      </view>
      <view class="exp-node__label">{{item.point_name}}</view>
    </view>
  </view>

  <!-- ─── 推荐点 ─── -->
  <view class="exp-next" wx:if="{{recommendedPoint}}">
    <view class="exp-next__label">推荐前行</view>
    <view class="exp-next__name">{{recommendedPoint.point_name}}</view>
    <view class="exp-next__relic">可获得 · {{recommendedPoint.relic_name}}</view>
  </view>

  <!-- ─── 探索印记（信物入口，非列表） ─── -->
  <view class="exp-section">
    <view class="exp-section__title">探索印记</view>
    <view class="exp-relics">
      <view
        class="exp-relic exp-relic--{{item.state}}"
        wx:for="{{points}}"
        wx:key="point_id"
        data-point-id="{{item.point_id}}"
        bindtap="onOpenScanShell"
      >
        <view class="exp-relic__icon">
          <view class="exp-relic__glow"></view>
          <text class="exp-relic__char">{{item.point_name.slice(0, 1)}}</text>
        </view>
        <view class="exp-relic__name">{{item.point_name}}</view>
        <view class="exp-relic__status">{{item.statusLabel}}</view>
      </view>
    </view>
  </view>

  <user-bottom-nav activeKey="{{activeTab}}" bind:change="onBottomNavChange" />
  <pilot-fx-overlay id="pilotFx" />
</view>
