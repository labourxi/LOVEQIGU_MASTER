/* ═══════════════════════════════════════════════════════════════════
   SCENIC_LANDING — 景区扫码入口 Landing Page

   纯景区背景图 + WXML 渲染的文字层 + 登录区
   ═══════════════════════════════════════════════════════════════════ */

/* ─── PAGE CONTAINER ─── */
.sl-page {
  position: relative;
  width: 100vw;
  height: 100vh;
  height: 100dvh;
  background: #0A1A14;
  overflow: hidden;
}

/* ═══ BACKGROUND ═══ */
.sl-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.sl-bg__image {
  width: 100%;
  height: 100%;
  display: block;
}

/* ═══ LOGIN FIXED ═══ */
.sl-login-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

.sl-login-fixed__btn {
  width: 480rpx;
  height: 100rpx;
  margin-bottom: 10rpx;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 0;
  pointer-events: auto;
  position: relative;
}

.sl-login-fixed__btn::after {
  content: '';
  position: absolute;
  inset: -20rpx;
}

.sl-login-fixed__btn--disabled {
  opacity: 0 !important;
  pointer-events: none;
}

/* ═══ AGREEMENT — 金色高亮 ═══ */
.sl-login-fixed__agreement {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  pointer-events: auto;
  padding: 14rpx 48rpx;
}

.sl-agreement-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sl-agreement-checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid #C8A24A;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(200, 162, 74, 0.08);
  transition: all 0.2s ease;
}

.sl-agreement-checkbox:active {
  background: rgba(200, 162, 74, 0.2);
}

.sl-agreement-checkbox__checked {
  width: 20rpx;
  height: 20rpx;
  border-radius: 3rpx;
  background: #C8A24A;
  position: relative;
}

.sl-agreement-checkbox__checked::after {
  content: '';
  position: absolute;
  left: 6rpx;
  top: 2rpx;
  width: 8rpx;
  height: 14rpx;
  border: solid #0A1A14;
  border-width: 0 2.5rpx 2.5rpx 0;
  transform: rotate(45deg);
}

.sl-agreement-text {
  font-size: 24rpx;
  color: #C8A24A;
  letter-spacing: 2rpx;
  font-weight: 400;
}

.sl-agreement-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.sl-agreement-link {
  font-size: 24rpx;
  color: #C8A24A;
  letter-spacing: 2rpx;
  font-weight: 400;
  text-decoration: underline;
  text-decoration-color: rgba(200, 162, 74, 0.3);
}

.sl-agreement-link:active {
  color: #D4B86A;
}
