<view class="proto-page user-phase1-page rights-page">
  <view class="rights-hero">
    <view class="rights-hero__title">探索礼遇</view>
    <view class="rights-hero__copy">完成探索后，在地商家为你留下一份温和的礼遇。这不是商城货架，而是旅程的延续。</view>
  </view>

  <view class="rights-zone">
    <view class="rights-zone__head">
      <view class="rights-zone__title">当前可用</view>
      <view class="rights-zone__hint">{{activeRights.length}} 项</view>
    </view>
    <view class="rights-gift-panel">
      <view class="rights-gift-row" wx:for="{{activeRights}}" wx:key="id">
        <view class="rights-gift-row__seal">礼</view>
        <view class="rights-gift-row__body">
          <view class="rights-gift-row__title">{{item.title}}</view>
          <view class="rights-gift-row__merchant">{{item.merchant}}</view>
          <view class="rights-gift-row__note">{{item.note}}</view>
          <view class="rights-source">{{item.source}}</view>
          <view class="rights-qr-placeholder" wx:if="{{item.showQr}}">到店出示 · 核销码占位</view>
        </view>
        <view class="rights-gift-row__status">{{item.status}}</view>
      </view>
      <view class="rights-empty-hint" wx:if="{{!activeRights.length}}">完成探索任务后，礼遇将在此显现</view>
    </view>
  </view>

  <view class="rights-zone">
    <view class="rights-zone__head">
      <view class="rights-zone__title">推荐领取</view>
      <view class="rights-zone__hint">来自 {{eventSummary.title}}</view>
    </view>
    <view class="rights-gift-panel">
      <view class="rights-gift-row" wx:for="{{recommendRights}}" wx:key="id">
        <view class="rights-gift-row__seal">荐</view>
        <view class="rights-gift-row__body">
          <view class="rights-gift-row__title">{{item.title}}</view>
          <view class="rights-gift-row__merchant">{{item.merchant}}</view>
          <view class="rights-gift-row__note">{{item.note}}</view>
          <view class="rights-source">来自探索</view>
        </view>
        <view class="rights-gift-row__status">{{item.status}}</view>
      </view>
      <view class="rights-empty-hint" wx:if="{{!recommendRights.length}}">继续探索，解锁更多在地礼遇</view>
    </view>
  </view>

  <view class="rights-zone">
    <view class="rights-zone__title" style="margin-bottom: 16rpx;">使用方式</view>
    <view class="rights-guide-panel">
      <view class="rights-guide-panel__copy">{{usageGuide.intro}}</view>
      <view class="rights-guide-steps">
        <view class="rights-guide-step" wx:for="{{usageGuide.steps}}" wx:for-index="idx" wx:key="idx">
          <view class="rights-guide-step__num">{{idx + 1}}</view>
          <view>{{item}}</view>
        </view>
      </view>
    </view>
  </view>

  <user-bottom-nav activeKey="{{activeTab}}" bind:change="onBottomNavChange" />
</view>
