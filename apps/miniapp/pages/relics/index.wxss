@import '../../styles/v59-system.wxss';

/* ════════════════════════════════════════════════════════════════
   CANONICAL PAGE_06 — 我的信物 (My Relics)
   
   Canonical sources:
     RELIC_VISUAL_CANON_V1   — circular composition, single node focus
     RELIC_CANON_V2          — relic = growth node (NOT collectible)
     RELIC_CONTENT_DENSITY_RULE_V1 — 1-line description, 1-sentence echo
   
   Visual rules enforced:
     - circular composition (orbit + ring + center)
     - no card-based gallery UI
     - no gamified UI patterns
     - Eastern style: restrained, minimalist, mysterious
   ════════════════════════════════════════════════════════════════ */

/* ─── PAGE CONTAINER ─── */
.canonical-collection-page {
  min-height: 100vh;
  background: #F4F1EB;
  padding: 40rpx 28rpx 140rpx;
  box-sizing: border-box;
}

/* ─── CANONICAL HEADER ─── */
.canonical-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.canonical-header__title {
  font-size: 36rpx;
  color: #263A34;
  font-weight: 700;
  letter-spacing: 4rpx;
  display: block;
}

.canonical-header__subtitle {
  font-size: 24rpx;
  color: rgba(38, 58, 52, 0.35);
  margin-top: 8rpx;
  letter-spacing: 4rpx;
  font-weight: 300;
  display: block;
}

.canonical-header__progress {
  font-size: 22rpx;
  color: rgba(200, 162, 74, 0.6);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
  display: block;
}

/* ─── CANONICAL SUB-NAV ─── */
.canonical-subnav {
  display: flex;
  flex-direction: row;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
  padding: 6rpx;
  background: rgba(200, 162, 74, 0.06);
  border-radius: 999rpx;
}

.canonical-subnav__item {
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.canonical-subnav__item.is-active {
  background: #FAF8F4;
  box-shadow: 0 2rpx 8rpx rgba(200, 162, 74, 0.12);
}

.canonical-subnav__label {
  font-size: 24rpx;
  color: rgba(38, 58, 52, 0.4);
  letter-spacing: 2rpx;
  font-weight: 500;
}

.canonical-subnav__item.is-active .canonical-subnav__label {
  color: #263A34;
  font-weight: 600;
}

/* ─── CIRCULAR RELIQUARY ───
     RELIC_VISUAL_CANON_V1: circular composition, single node focus
     UI Contract V0.5: 已获得信物（环形轨道）
     Each relic orbits around a conceptual center.
     Flex-wrap creates radial wrapping; the layout reads like a cosmos.
   ─── */
.canonical-reliquary {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 20rpx;
  position: relative;
  min-height: 400rpx;
}

/* Single relic node — orbital element */
.canonical-relic-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  min-width: 160rpx;
  max-width: 180rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
}

.canonical-relic-node:active {
  background: rgba(250, 248, 244, 0.9);
  transform: scale(0.98);
}

/* Circular orbit container */
.canonical-relic-node__orbit {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

/* Outer ring — circular composition */
.canonical-relic-node__ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border-width: 1.5rpx;
  border-style: solid;
  opacity: 0.4;
  animation: canonical-ring-pulse 4s ease-in-out infinite;
}

@keyframes canonical-ring-pulse {
  0%, 100% { transform: scale(1); opacity: 0.4; }
  50% { transform: scale(1.05); opacity: 0.7; }
}

/* Center symbol — circular focus */
.canonical-relic-node__center {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-width: 1.5rpx;
  border-style: solid;
}

.canonical-relic-node__symbol {
  font-size: 36rpx;
  opacity: 0.7;
}

/* Information — compact vertical for orbit layout */
.canonical-relic-node__info {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  max-width: 140rpx;
}

.canonical-relic-node__name {
  font-size: 24rpx;
  color: #263A34;
  font-weight: 600;
  letter-spacing: 1rpx;
  text-align: center;
}

/* RELIC_CONTENT_DENSITY_RULE_V1: 1-line description only */
.canonical-relic-node__description {
  font-size: 20rpx;
  color: rgba(38, 58, 52, 0.4);
  letter-spacing: 1rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 130rpx;
}

/* Echo = 1 sentence philosophical response */
.canonical-relic-node__echo {
  font-size: 20rpx;
  color: rgba(200, 162, 74, 0.7);
  letter-spacing: 1rpx;
  margin-top: 4rpx;
  font-style: italic;
}

.canonical-relic-node__blessing {
  font-size: 20rpx;
  color: rgba(200, 162, 74, 0.5);
  letter-spacing: 1rpx;
  margin-top: 2rpx;
}

/* ─── EMPTY STATE — canonical no-system-language ─── */
.canonical-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 20rpx;
}

.canonical-empty__orbit {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.canonical-empty__ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 1.5rpx dashed rgba(200, 162, 74, 0.15);
}

.canonical-empty__center {
  font-size: 56rpx;
  color: rgba(200, 162, 74, 0.2);
}

.canonical-empty__text {
  font-size: 26rpx;
  color: rgba(38, 58, 52, 0.4);
  letter-spacing: 2rpx;
  text-align: center;
  line-height: 1.6;
}

.canonical-empty__hint {
  font-size: 22rpx;
  color: rgba(200, 162, 74, 0.4);
  letter-spacing: 1rpx;
  text-align: center;
}

/* ════════════════════════════════════════════════════════════════
   PAGE_07A — 天之图鉴 (Heaven Atlas)
   PAGE_07B — 人之图鉴 (Human Atlas)
   ════════════════════════════════════════════════════════════════ */

.canonical-atlas {
  padding: 0 8rpx;
}

.canonical-atlas__summary {
  font-size: 22rpx;
  color: rgba(200, 162, 74, 0.6);
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 32rpx;
  text-align: center;
}

/* Star lodge group (星宿) / Meridian group (经络) */
.canonical-lodge-group,
.canonical-meridian-group {
  margin-bottom: 40rpx;
  padding: 24rpx;
  background: rgba(250, 248, 244, 0.4);
  border-radius: 20rpx;
  border: 1rpx solid rgba(200, 162, 74, 0.06);
}

.canonical-lodge-group__header,
.canonical-meridian-group__header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.canonical-lodge-group__name,
.canonical-meridian-group__name {
  font-size: 26rpx;
  color: #263A34;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.canonical-lodge-group__progress,
.canonical-meridian-group__progress {
  font-size: 22rpx;
  color: rgba(200, 162, 74, 0.5);
  letter-spacing: 1rpx;
}

/* Star nodes — circular composition */
.canonical-lodge-group__stars,
.canonical-meridian-group__points {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.canonical-star-node,
.canonical-acupoint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  width: 96rpx;
  cursor: pointer;
}

.canonical-star-node__orb,
.canonical-acupoint__node {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-width: 1.5rpx;
  border-style: solid;
}

.canonical-star-node__symbol,
.canonical-acupoint__symbol {
  font-size: 28rpx;
  opacity: 0.6;
}

.canonical-star-node__name,
.canonical-acupoint__name {
  font-size: 20rpx;
  color: rgba(38, 58, 52, 0.5);
  letter-spacing: 1rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 96rpx;
}

/* Four symbols (四象) summary */
.canonical-foursymbols {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(250, 248, 244, 0.6);
  border-radius: 20rpx;
  border: 1rpx solid rgba(200, 162, 74, 0.08);
}

.canonical-foursymbols__title {
  font-size: 26rpx;
  color: #263A34;
  font-weight: 600;
  letter-spacing: 4rpx;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
}

.canonical-foursymbols__grid {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
}

.canonical-foursymbol {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.canonical-foursymbol__orb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-width: 2rpx;
  border-style: solid;
  opacity: 0.7;
}

.canonical-foursymbol__name {
  font-size: 22rpx;
  color: rgba(38, 58, 52, 0.5);
  letter-spacing: 2rpx;
}

/* ════════════════════════════════════════════════════════════════
   PAGE_07C — 信物详情 Modal (Relic Detail)
   Circular focus + Echo display
   ════════════════════════════════════════════════════════════════ */

.canonical-modal {
  position: fixed;
  inset: 0;
  z-index: 20000;
  background: rgba(10, 26, 20, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.canonical-modal__content {
  position: relative;
  width: 100%;
  max-height: 80vh;
  background: #FAF8F4;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 36rpx;
  box-sizing: border-box;
  overflow-y: auto;
  box-shadow: 0 16rpx 48rpx rgba(10, 26, 20, 0.2);
}

.canonical-modal__close {
  position: absolute;
  top: 16rpx;
  right: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.canonical-modal__close-icon {
  font-size: 40rpx;
  color: rgba(38, 58, 52, 0.3);
}

/* Circular detail view */
.canonical-detail {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.canonical-detail__orbit {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.canonical-detail__ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border-width: 2rpx;
  border-style: solid;
  opacity: 0.6;
  animation: canonical-ring-pulse 4s ease-in-out infinite;
}

.canonical-detail__center {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-width: 2rpx;
  border-style: solid;
}

.canonical-detail__symbol {
  font-size: 56rpx;
  opacity: 0.7;
}

.canonical-detail__name {
  font-size: 34rpx;
  color: #263A34;
  font-weight: 700;
  letter-spacing: 4rpx;
}

/* 1-line description (RELIC_CONTENT_DENSITY_RULE_V1) */
.canonical-detail__description {
  font-size: 24rpx;
  color: rgba(38, 58, 52, 0.4);
  text-align: center;
  letter-spacing: 1rpx;
  line-height: 1.6;
  max-width: 80%;
}

/* Echo = 1 sentence philosophical response */
.canonical-detail__echo {
  font-size: 22rpx;
  color: rgba(200, 162, 74, 0.7);
  text-align: center;
  letter-spacing: 1rpx;
  font-style: italic;
  margin-top: 8rpx;
}

.canonical-detail__blessing {
  font-size: 20rpx;
  color: rgba(200, 162, 74, 0.5);
  letter-spacing: 2rpx;
}

.canonical-detail__origin {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  margin-top: 16rpx;
}

.canonical-detail__origin-label {
  font-size: 22rpx;
  color: rgba(38, 58, 52, 0.3);
  letter-spacing: 1rpx;
}

.canonical-detail__origin-value {
  font-size: 22rpx;
  color: rgba(38, 58, 52, 0.5);
  letter-spacing: 1rpx;
}
