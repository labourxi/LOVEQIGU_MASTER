<view class="page sub-page">
  <view class="page-title">我的信物</view>
  <view class="page-desc">{{assetNote}}</view>

  <view class="group" wx:for="{{groups}}" wx:key="title">
    <view class="group-head">
      <view>
        <view class="group-label">章节分组</view>
        <view class="group-title">{{item.title}}</view>
      </view>
      <view class="group-progress">{{item.progress}}</view>
    </view>

    <view class="list">
      <view class="list-card" wx:for="{{item.relics}}" wx:for-item="relic" wx:key="name">
        <view class="card-title">{{relic.name}}</view>
        <view class="card-meta">{{relic.type}}</view>
        <view class="card-copy">{{relic.source}}</view>
      </view>
    </view>
  </view>
</view>
