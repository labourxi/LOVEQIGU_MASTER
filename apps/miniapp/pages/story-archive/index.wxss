.mvp-page {
  padding-top: 48rpx;
}

.page-title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
}

.page-desc,
.card-copy {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.page-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.rule-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.rule-chip,
.card-status {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #e8d8b4;
  color: #263a34;
  font-size: 22rpx;
  font-weight: 700;
}

.archive-panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 8rpx;
  background: #263a34;
}

.panel-label {
  color: #d6c08d;
  font-size: 22rpx;
  font-weight: 800;
}

.panel-copy {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.5;
}

.panel-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 224rpx;
  height: 60rpx;
  margin: 20rpx 0 0;
  padding: 0;
  border-radius: 30rpx;
  background: #d6c08d;
  color: #15171c;
  font-size: 24rpx;
  font-weight: 700;
}

.panel-button::after {
  border: 0;
}

.timeline {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 34rpx;
  padding-left: 34rpx;
}

.timeline::before {
  position: absolute;
  top: 12rpx;
  bottom: 12rpx;
  left: 10rpx;
  width: 2rpx;
  background: #d6c08d;
  content: '';
}

.timeline-item {
  position: relative;
}

.timeline-dot {
  position: absolute;
  top: 28rpx;
  left: -34rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #263a34;
}

.timeline-card {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.phase {
  color: #7f4f24;
  font-size: 22rpx;
  font-weight: 800;
}

.card-title {
  margin-top: 8rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.card-copy {
  margin-top: 12rpx;
}
