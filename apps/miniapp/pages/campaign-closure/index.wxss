.journey-page {
  padding-top: 48rpx;
}

.page-title {
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
}

.page-desc,
.card-copy,
.card-meta,
.section-subtitle {
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.5;
}

.page-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.chip,
.card-tag {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #e8d8b4;
  color: #263a34;
  font-size: 22rpx;
  font-weight: 700;
}

.section {
  margin-top: 34rpx;
}

.section-head {
  margin-bottom: 16rpx;
}

.section-title {
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.section-subtitle {
  margin-top: 8rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.journey-card {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.card-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.card-copy {
  margin-top: 12rpx;
}

.card-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 224rpx;
  height: 60rpx;
  margin: 24rpx 0 0;
  padding: 0;
  border-radius: 30rpx;
  background: #263a34;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.card-button::after {
  border: 0;
}
