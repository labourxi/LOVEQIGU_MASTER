@import '../../styles/prototype-v1.wxss';

.star-map-page {
  padding-bottom: 64rpx;
}

.star-map-toolbar {
  margin-bottom: 24rpx;
}

.star-map-back {
  margin: 0;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  background: #e8efe9;
  color: #263a34;
  font-size: 24rpx;
  font-weight: 700;
}

.star-map-back::after {
  border: 0;
}

.symbol-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.symbol-card {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff;
  box-shadow: 0 8rpx 24rpx rgba(17, 24, 39, 0.06);
}

.symbol-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.symbol-card-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.4;
}

.symbol-card-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.symbol-card-note {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #9ca3af;
}

.mansion-card {
  margin-bottom: 20rpx;
}

.mansion-card--focus {
  border: 2rpx solid #4b635c;
}

.mansion-progress {
  margin: 12rpx 0 16rpx;
}

.proto-chip {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 120rpx;
  padding: 12rpx 16rpx;
}

.star-chip-name {
  font-size: 24rpx;
  font-weight: 700;
}

.star-chip-status {
  margin-top: 4rpx;
  font-size: 20rpx;
  opacity: 0.85;
}

.proto-chip--focus {
  box-shadow: 0 0 0 3rpx rgba(244, 215, 166, 0.9);
  transform: scale(1.02);
}

.cultural-copy,
.cultural-panel {
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 12rpx;
  background: #faf8f4;
  color: #4b635c;
  font-size: 24rpx;
  line-height: 1.6;
  white-space: pre-line;
}

.cultural-panel {
  margin-bottom: 16rpx;
}
