<view class="proto-page user-phase1-page" wx:if="{{!missing}}">
  <view class="proto-hero">
    <view class="proto-kicker">探索点</view>
    <view class="proto-title">{{scenic.name}}</view>
    <view class="proto-subtitle">{{scenic.intro}}</view>
  </view>

  <view class="proto-section">
    <view class="scenic-scroll-flow">
      <view class="scenic-flow-block">
        <view class="scenic-flow-kicker">为何而来</view>
        <view class="scenic-flow-copy">{{scenic.feature}}</view>
        <view class="proto-card-meta" style="margin-top: 12rpx;">{{scenic.area}} · {{scenic.explorationPointsDisplay}} 处探索印记</view>
      </view>
      <view class="scenic-flow-block">
        <view class="scenic-flow-kicker">可获得信物</view>
        <view class="scenic-flow-copy">完成打卡与显现仪式后，探索印记将归入你的收藏册。信物承载故事，记录你与这片土地的相遇。</view>
        <view class="scenic-relic-chip">信物 · 故事进度资产</view>
      </view>
      <view class="scenic-flow-block">
        <view class="scenic-flow-kicker">显现 · AR</view>
        <view class="scenic-flow-copy">抵达探索点后，可触发 AR 显现，以克制仪式感呈现印记与祝福。</view>
        <button class="proto-btn proto-btn--primary" style="margin-top: 20rpx;" bindtap="onStartCheckIn">开始打卡</button>
      </view>
      <view class="scenic-flow-block" wx:if="{{nearbyCoupons.length}}">
        <view class="scenic-flow-kicker">附近礼遇</view>
        <view wx:for="{{nearbyCoupons}}" wx:key="id" style="margin-top: 16rpx;">
          <view class="scenic-flow-copy">{{item.name}} · {{item.merchant}}</view>
          <view class="rights-source">探索礼遇</view>
        </view>
      </view>
      <view class="scenic-flow-block" wx:else>
        <view class="scenic-flow-kicker">附近礼遇</view>
        <view class="scenic-flow-copy">继续探索，在地商家的礼遇将在此显现。</view>
      </view>
    </view>
  </view>

  <view class="proto-section action-row">
    <button class="proto-btn" bindtap="onOpenExplore">返回探索图谱</button>
    <button class="proto-btn proto-btn--ghost" bindtap="onNavigate">导航前往</button>
  </view>

  <user-bottom-nav activeKey="{{activeTab}}" bind:change="onBottomNavChange" />
</view>

<view class="proto-page" wx:else>
  <view class="proto-card">
    <view class="proto-card-title">{{title}}</view>
  </view>
</view>
