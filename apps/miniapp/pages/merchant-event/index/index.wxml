<view class="proto-page">
  <view class="proto-hero">
    <view class="proto-kicker">首场活动运行入口</view>
    <view class="proto-title">{{activity.event_name}}</view>
    <view class="proto-subtitle">{{activity.description}}</view>
    <view class="proto-stats">
      <view class="proto-stat" wx:for="{{stats}}" wx:key="label">
        <view class="proto-stat-value">{{item.value}}</view>
        <view class="proto-stat-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="proto-section">
    <view class="proto-section-head">
      <view class="proto-section-title">活动状态</view>
      <view class="proto-section-more">{{activity.status}}</view>
    </view>
    <view class="proto-card">
      <view class="proto-card-meta">开始时间：{{activity.start_time}}</view>
      <view class="proto-card-meta">结束时间：{{activity.end_time}}</view>
      <view class="proto-card-copy">进入后可以查看探索点、完成任务、获得信物并领取卡券，刷新后状态会保留。</view>
      <button class="proto-btn proto-btn--primary" bindtap="onOpenExploration">进入探索列表</button>
    </view>
  </view>

  <view class="proto-section">
    <view class="proto-section-head">
      <view class="proto-section-title">探索点</view>
      <view class="proto-section-more">点进详情查看任务与信物</view>
    </view>
    <view class="proto-card" wx:for="{{points}}" wx:key="point_id" data-point-id="{{item.point_id}}" bindtap="onOpenPoint">
      <view class="proto-row">
        <view class="proto-card-title">{{item.point_name}}</view>
        <view class="proto-badge">{{item.task_status}}</view>
      </view>
      <view class="proto-card-meta">{{item.merchant_name}} 路 {{item.task_name}}</view>
      <view class="proto-card-copy">卡券状态：{{item.coupon_status}} | 信物：{{item.relic_name}}</view>
    </view>
  </view>

  <view class="proto-section">
    <view class="proto-section-head">
      <view class="proto-section-title">任务</view>
      <view class="proto-section-more">完成后会发放信物</view>
    </view>
    <view class="proto-card" wx:for="{{tasks}}" wx:key="task_id">
      <view class="proto-row">
        <view class="proto-card-title">{{item.task_name}}</view>
        <view class="proto-badge">{{item.status}}</view>
      </view>
      <view class="proto-card-meta">{{item.task_type}} 路 奖励：{{item.task_reward}}</view>
      <button
        wx:if="{{item.status !== 'COMPLETED'}}"
        class="proto-btn proto-btn--ghost"
        data-task-id="{{item.task_id}}"
        catchtap="onCompleteTask"
      >
        完成任务
      </button>
    </view>
  </view>

  <view class="proto-section">
    <view class="proto-section-head">
      <view class="proto-section-title">信物</view>
      <view class="proto-section-more">完成任务后自动可见</view>
    </view>
    <view class="proto-card" wx:for="{{relics}}" wx:key="relic_id">
      <view class="proto-row">
        <view class="proto-card-title">{{item.relic_name}}</view>
        <view class="proto-badge">{{item.status}}</view>
      </view>
      <view class="proto-card-meta">{{item.rarity}}</view>
      <view class="proto-card-copy">{{item.story_snippet}}</view>
    </view>
  </view>

  <view class="proto-section">
    <view class="proto-section-head">
      <view class="proto-section-title">卡券</view>
      <view class="proto-section-more">可领取状态由任务与信物决定</view>
    </view>
    <view class="proto-card" wx:for="{{coupons}}" wx:key="coupon_id">
      <view class="proto-row">
        <view class="proto-card-title">{{item.coupon_name}}</view>
        <view class="proto-badge proto-badge--warm">{{item.status}}</view>
      </view>
      <view class="proto-card-meta">{{item.merchant_name}} 路 {{item.coupon_type}} 路 {{item.discount_value}}</view>
      <button
        wx:if="{{item.status === 'AVAILABLE'}}"
        class="proto-btn"
        data-coupon-id="{{item.coupon_id}}"
        catchtap="onClaimCoupon"
      >
        领取卡券
      </button>
    </view>
  </view>
</view>

