@import '../../../styles/prototype-v1.wxss';
@import '../../../styles/user-phase1.wxss';

.point-journal-scroll {
  padding: 28rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(38, 58, 52, 0.08);
}

.point-journal-block {
  padding-bottom: 32rpx;
  margin-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(38, 58, 52, 0.06);
}

.point-journal-block:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: 0;
}

.point-journal-row {
  margin-top: 12rpx;
}

.point-journal-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #263a34;
}

.point-journal-title {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.point-journal-copy {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.7;
}

.point-journal-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.point-journal-badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: #e8efe9;
  color: #4b635c;
}

.point-journal-badge--warm {
  background: #f1ece2;
  color: #7f4f24;
}

.point-journal-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.point-journal-actions .proto-btn {
  flex: 1;
}

.xr-product-entry-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fffaf0;
  border: 1rpx solid #ead7b0;
}

.xr-product-entry-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #25332b;
}

.xr-product-entry-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #677168;
}

.xr-product-entry-status {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #5d665f;
  word-break: break-all;
}

.xr-product-entry-ready {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #eff9f0;
  color: #2f6b39;
  font-size: 24rpx;
  line-height: 1.6;
}

.xr-product-entry-fallback {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fff3e4;
  color: #9a5f00;
  font-size: 24rpx;
  line-height: 1.6;
}