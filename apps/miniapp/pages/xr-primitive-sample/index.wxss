.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f4f1eb;
}

.hero {
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f3f35;
  line-height: 1.3;
}

.copy {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #5a5345;
}

.card {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1px solid #e6dcc8;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f3f35;
  margin-bottom: 12rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #2d2d2d;
}

.row text:last-child {
  text-align: right;
  color: #2f5d4f;
  word-break: break-all;
}

.primitive-diagnostics-panel {
  margin: 16px 0;
  padding: 14px;
  border-radius: 12px;
  background: #fff6d8;
  border: 1px solid #e0b85a;
}

.primitive-diagnostics-button {
  width: 100%;
  min-height: 46px;
  line-height: 46px;
  font-size: 16px;
  font-weight: 600;
  background: #1f3f35;
  color: #ffffff;
  border-radius: 24px;
}

.primitive-diagnostics-hint {
  margin-top: 8px;
  font-size: 12px;
  color: #6f6040;
}

.xr-surface-shell {
  min-height: 360rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #111111;
  border: 1px solid #36453d;
}

.xr-surface-note {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #6e6044;
}
