/* 条款页面 — 浅色背景，清晰可读 */
.legal-page {
  min-height: 100vh;
  background: #F5F0E8;
  padding: 40rpx 44rpx 100rpx;
  box-sizing: border-box;
  color: #2C2C2C;
  font-weight: 400;
  line-height: 1.9;
  font-size: 28rpx;
}

.legal-header {
  font-size: 40rpx;
  color: #8B7355;
  letter-spacing: 6rpx;
  text-align: center;
  padding: 48rpx 0 40rpx;
  font-weight: 500;
}

.legal-section {
  margin-bottom: 40rpx;
}

.legal-section__title {
  font-size: 30rpx;
  color: #8B7355;
  letter-spacing: 3rpx;
  margin-bottom: 14rpx;
  font-weight: 500;
}

.legal-section__body {
  font-size: 28rpx;
  color: #444;
  letter-spacing: 2rpx;
  text-align: justify;
}

.legal-footer {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  letter-spacing: 4rpx;
  padding-top: 48rpx;
}
