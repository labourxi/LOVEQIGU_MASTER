.legal-page {
  min-height: 100vh;
  background: #0A1A14;
  padding: 40rpx 36rpx 80rpx;
  box-sizing: border-box;
  color: rgba(232, 224, 208, 0.6);
  font-weight: 300;
  line-height: 1.8;
}

.legal-header {
  font-size: 36rpx;
  color: rgba(200, 162, 74, 0.6);
  letter-spacing: 8rpx;
  text-align: center;
  padding: 48rpx 0 40rpx;
  font-weight: 400;
}

.legal-section {
  margin-bottom: 36rpx;
}

.legal-section__title {
  font-size: 26rpx;
  color: rgba(200, 162, 74, 0.4);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  font-weight: 400;
}

.legal-section__body {
  font-size: 24rpx;
  color: rgba(232, 224, 208, 0.4);
  letter-spacing: 2rpx;
  text-align: justify;
}

.legal-footer {
  text-align: center;
  font-size: 20rpx;
  color: rgba(232, 224, 208, 0.15);
  letter-spacing: 4rpx;
  padding-top: 40rpx;
}
