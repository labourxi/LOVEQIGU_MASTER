<view class="proto-page user-phase1-page">
  <view class="proto-hero">
    <view class="proto-kicker">游者</view>
    <view class="proto-title">{{loginBanner.title}}</view>
    <view class="proto-subtitle">你的探索印记与旅程记录</view>
  </view>

  <view class="proto-section">
    <view class="user-path-links">
      <view class="user-path-link">
        <view>
          <view class="user-path-link__title">{{snapshot.auth.user.nick_name}}</view>
          <view class="user-path-link__copy">角色 · {{snapshot.auth.user.role}}</view>
        </view>
        <view class="proto-badge">{{snapshot.auth.logged_in ? '已登录' : '未登录'}}</view>
      </view>
    </view>
    <view class="proto-row proto-row--actions" style="margin-top: 16rpx;">
      <button wx:if="{{!snapshot.auth.logged_in}}" class="proto-btn proto-btn--primary" bindtap="onMockLogin">微信登录</button>
      <button wx:if="{{snapshot.auth.logged_in}}" class="proto-btn proto-btn--ghost" bindtap="onMockLogout">退出登录</button>
      <button class="proto-btn" bindtap="onOpenProgress">探索进度</button>
    </view>
  </view>

  <view class="proto-section">
    <view class="user-echo-panel">
      <view class="user-echo-kicker">当前活动</view>
      <view class="user-echo-copy">{{snapshot.activity.event_name}}</view>
      <view class="proto-card-meta" style="margin-top: 12rpx;">
        任务 {{snapshot.stats.completedTaskCount}} / {{snapshot.stats.taskCount}} · 信物 {{snapshot.stats.ownedRelicCount}} · 礼遇 {{snapshot.stats.claimedCouponCount}}
      </view>
    </view>
  </view>

  <user-bottom-nav activeKey="{{activeTab}}" bind:change="onBottomNavChange" />
</view>
