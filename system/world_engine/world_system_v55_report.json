        { "id": "relic_garden_grove",      "name": "林荫印记",     "prio": 2, "prev": "relic_entrance_greeting",      "next": "relic_street_sign" },
        { "id": "relic_street_sign",       "name": "老街印记",     "prio": 3, "prev": "relic_garden_grove",           "next": "relic_gourmet_square" },
        { "id": "relic_gourmet_square",    "name": "食光印记",     "prio": 4, "prev": "relic_street_sign",            "next": "relic_courtyard" },
        { "id": "relic_courtyard",         "name": "绿庭印记",     "prio": 5, "prev": "relic_gourmet_square",         "next": "relic_waterfront" },
        { "id": "relic_waterfront",        "name": "水岸印记",     "prio": 6, "prev": "relic_courtyard",              "next": "relic_return_sign" },
        { "id": "relic_return_sign",       "name": "归途印记",     "prio": 7, "prev": "relic_waterfront",             "next": null }
      ]
    },
    {
      "world_id": "shanhaijing",
