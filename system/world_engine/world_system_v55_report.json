      "status": "RESERVED (not yet implemented)"
    },
    {
      "world_id": "dunhuang",
      "world_name": "敦煌",
      "status": "RESERVED (not yet implemented)"
    }
  ],

  "persistence": {
    "storageKey": "LOVEQIGU_WORLD_SYSTEM_V55",
    "savedFields": [
      "current_world_id",
      "completed_world_ids",
      "unlocked_world_ids",
      "total_relic_count",
      "collected_relic_ids",
      "每个 world: unlocked, completed, completion_rate, last_visited_at",
      "每个 relic node: collected, collected_at, visual_stage"
    ],
    "loadOnInit": true,
    "saveOnMutation": true
  },

  "validation": {
    "multiWorldStructure": true,
    "relicChainFormed": true,
    "worldEvolutionPossible": true,
    "xrIndependent": true,
    "usersCanMigrateAcrossWorlds": true,
    "worldLogicNotHardcodedInExplore": true,
    "relicIsolatedStructureBanned": true,
    "xrNotBoundToBusiness": true
  }
}
