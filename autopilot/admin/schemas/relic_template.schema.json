{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "loveqigu.admin.relic_template.v1",
  "title": "LOVEQIGU Admin Relic Template V1",
  "type": "object",
  "required": [
    "schema",
    "version",
    "relic_template_id",
    "chapter_id",
    "relic_type",
    "template_class",
    "required_art",
    "required_story",
    "required_rights",
    "dc_enabled",
    "status"
  ],
  "properties": {
    "schema": { "const": "loveqigu.admin.relic_template.v1" },
    "version": { "type": "string" },
    "relic_template_id": { "type": "string" },
    "chapter_id": { "type": "string" },
    "relic_type": { "type": "string" },
    "template_class": { "type": "string" },
    "required_art": { "type": "array", "items": { "type": "string" } },
    "required_story": { "type": "array", "items": { "type": "string" } },
    "required_rights": { "type": "array", "items": { "type": "string" } },
    "dc_enabled": { "type": "boolean" },
    "status": { "enum": ["draft", "active", "frozen", "retired"] },
    "canonical_boundary": { "type": "string" }
  },
  "additionalProperties": true
}
